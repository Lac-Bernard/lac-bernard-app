---
import Page from '../layouts/Page.astro';

const [page] = await Astro.glob('../../content/pages/environment.md');
if (!page) throw new Error('Missing content/pages/environment.md');

const title = page.frontmatter?.title || 'Environment';
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="environment" />
