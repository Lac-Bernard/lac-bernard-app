---
import Page from '../../layouts/Page.astro';

const [page] = await Astro.glob('../../../content/pages/community-regatta.md');
if (!page) throw new Error('Missing content/pages/community-regatta.md');

const title = page.frontmatter?.title || 'Annual Regatta';
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} />
