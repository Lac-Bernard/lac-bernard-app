---
import Page from '../../layouts/Page.astro';

const [page] = await Astro.glob('../../../content/pages/community-history.md');
if (!page) throw new Error('Missing content/pages/community-history.md');

const title = page.frontmatter?.title || 'History';
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="community" />
