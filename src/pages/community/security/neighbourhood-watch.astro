---
import Page from '../../../layouts/Page.astro';
import { type Language } from '../../../utils/i18n';

const currentPath = Astro.url.pathname;
const currentLang = (Astro.currentLocale || 'en') as Language;

const [page] = currentLang === 'fr' 
  ? await Astro.glob('../../../../content/pages/fr/community-security-neighbourhood-watch.md')
  : await Astro.glob('../../../../content/pages/community-security-neighbourhood-watch.md');
if (!page) throw new Error(`Missing content/pages/${currentLang === 'fr' ? 'fr/' : ''}community-security-neighbourhood-watch.md`);

const titles = {
  en: 'Neighbourhood Watch Program',
  fr: 'Programme de surveillance de quartier',
};

const title = page.frontmatter?.title || titles[currentLang];
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="community" />