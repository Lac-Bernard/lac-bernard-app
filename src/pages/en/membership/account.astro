---
import MemberHomeView from '../../../components/members/MemberHomeView.astro';
import { createSupabasePageClient } from '../../../lib/supabase/server';
import { loadMemberAccountData } from '../../../lib/members/accountData';
import { memberPaths } from '../../../lib/members/i18n';
import { getMembershipCalendarYear } from '../../../lib/members/membershipYear';

const paths = memberPaths.en;
const { supabase, flushCookies, redirectWithCookies } = createSupabasePageClient(
	Astro.request,
	Astro.cookies,
);
const {
	data: { user },
	error,
} = await supabase.auth.getUser();

if (error || !user) {
	return redirectWithCookies(`${paths.signIn}?next=${encodeURIComponent(Astro.url.pathname)}`);
}

const currentYear = getMembershipCalendarYear();

await supabase.rpc('claim_member');

const accountData = await loadMemberAccountData(supabase, user.email ?? '', currentYear);

if (!accountData.member) {
	const join = `${paths.join}?next=${encodeURIComponent(paths.account)}`;
	return redirectWithCookies(join);
}

flushCookies();
const email = user.email ?? '';
const checkoutParam = Astro.url.searchParams.get('checkout');
const checkoutFlash =
	checkoutParam === 'success' ? 'success' : checkoutParam === 'cancelled' ? 'cancelled' : null;
---

<MemberHomeView
	locale="en"
	email={email}
	currentYear={currentYear}
	accountData={accountData}
	checkoutFlash={checkoutFlash}
/>
