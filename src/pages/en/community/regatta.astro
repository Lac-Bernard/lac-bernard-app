---
import Page from '@/layouts/Page.astro';
import { loadContentPage } from '@/utils/loadContentPage';

const page = await loadContentPage('en', 'community-regatta');
const title = page.frontmatter?.title ?? "Annual Regatta";
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="community" />
