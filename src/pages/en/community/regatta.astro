---
import Page from '../../../layouts/Page.astro';
import { type Language } from '../../../utils/i18n';

const currentPath = Astro.url.pathname;
const currentLang = (Astro.currentLocale || 'en') as Language;

const [page] = currentLang === 'fr' 
  ? await Astro.glob('../../../../content/pages/fr/community-regatta.md')
  : await Astro.glob('../../../../content/pages/community-regatta.md');
if (!page) throw new Error(`Missing content/pages/${currentLang === 'fr' ? 'fr/' : ''}community-regatta.md`);

const titles = {
  en: 'Annual Regatta',
  fr: 'Régate annuelle',
};

const title = page.frontmatter?.title || titles[currentLang];
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="community" />
