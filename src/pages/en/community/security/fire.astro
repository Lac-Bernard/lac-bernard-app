---
import Page from '../../../../layouts/Page.astro';
import { type Language } from '../../../../utils/i18n';

const currentPath = Astro.url.pathname;
const currentLang = (Astro.currentLocale || 'en') as Language;

const [page] = currentLang === 'fr' 
  ? await Astro.glob('../../../../../content/pages/fr/community-security-fire.md')
  : await Astro.glob('../../../../../content/pages/en/community-security-fire.md');
if (!page) throw new Error(`Missing content/pages/${currentLang === 'fr' ? 'fr/' : 'en/'}community-security-fire.md`);

const titles = {
  en: 'Fire',
  fr: 'Incendie',
};

const title = page.frontmatter?.title || titles[currentLang];
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="community" />