---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import '../../styles/theme.css';
import '../../styles/components.css';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import FormattedDate from '../../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>News | Lac Bernard Association</title>
		<meta name="description" content="Latest news and updates from the Lac Bernard Association" />
	</head>

	<body>
		<SiteHeader />

		<main id="main-content">
			<section class="section">
				<div class="container">
					<div class="blogHeader">
						<h1>Latest News</h1>
						<p class="muted">Stay up to date with the latest news and updates from the Lac Bernard Association.</p>
					</div>
					
					<div class="postsList">
						{posts.map((post) => (
							<article class="postCard">
								<a href={`/news/${post.id}/`} class="postLink">
									{post.data.heroImage && (
										<div class="postImage">
											<Image width={720} height={360} src={post.data.heroImage} alt="" />
										</div>
									)}
									<div class="postContent">
										<h2>{post.data.title}</h2>
										<p class="postDescription">{post.data.description}</p>
										<div class="postDate">
											<FormattedDate date={post.data.pubDate} />
										</div>
									</div>
								</a>
							</article>
						))}
					</div>
				</div>
			</section>
		</main>

		<SiteFooter />

		<style>
			.blogHeader {
				max-width: 720px;
				margin: 0 auto 40px;
			}
			
			.blogHeader h1 {
				margin: 0 0 12px;
				font-size: clamp(32px, 4vw, 48px);
				line-height: 1.2;
				letter-spacing: -.02em;
			}
			
			.postsList {
				display: flex;
				flex-direction: column;
				gap: 32px;
				max-width: 900px;
				margin: 0 auto;
			}
			
			.postCard {
				border: 1px solid var(--border);
				border-radius: 12px;
				overflow: hidden;
				background: rgba(255,255,255,.8);
				transition: all 150ms ease;
			}
			
			.postCard:hover {
				box-shadow: var(--shadow);
				transform: translateY(-2px);
			}
			
			.postLink {
				display: block;
				text-decoration: none;
				color: inherit;
			}
			
			.postImage {
				width: 100%;
				overflow: hidden;
			}
			
			.postImage img {
				width: 100%;
				height: auto;
				display: block;
				transition: transform 150ms ease;
			}
			
			.postCard:hover .postImage img {
				transform: scale(1.02);
			}
			
			.postContent {
				padding: 24px;
			}
			
			.postContent h2 {
				margin: 0 0 12px;
				font-size: 24px;
				font-weight: 600;
				line-height: 1.3;
				color: var(--text);
			}
			
			.postDescription {
				margin: 0 0 16px;
				color: var(--muted);
				font-size: 17px;
				line-height: 1.5;
			}
			
			.postDate {
				color: var(--muted);
				font-size: 14px;
			}
			
			.postCard:hover .postContent h2 {
				color: var(--color-primary);
			}
			
			@media (max-width: 720px) {
				.postsList {
					gap: 24px;
					margin-top: 32px;
				}
				
				.postContent {
					padding: 20px;
				}
				
				.postContent h2 {
					font-size: 20px;
				}
			}
		</style>
	</body>
</html>
