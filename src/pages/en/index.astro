---
import '../../styles/theme.css';
import '../../styles/components.css';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { getLocalizedHref, type Language } from '../../utils/i18n';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const currentLang = (Astro.currentLocale || 'en') as Language;

// Load content based on language - Astro.glob requires literal strings
const [home] = currentLang === 'fr' 
  ? await Astro.glob('../../../content/pages/fr/home.md')
  : await Astro.glob('../../../content/pages/home.md');
if (!home) throw new Error(`Missing content/pages/${currentLang === 'fr' ? 'fr/' : ''}home.md`);

const { Content, frontmatter } = home;

// Get latest blog post by pubDate (English version - doesn't end with -fr)
const allPosts = await getCollection('blog');
const latestPost = allPosts
  .filter(post => !post.id.endsWith('-fr'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())[0];

const titles = {
  en: {
    site: 'Lac Bernard Association',
    hero: frontmatter?.heroTitle ?? 'Welcome to the Lac Bernard Association',
    subtitle: frontmatter?.heroSubtitle ?? '',
    kicker: 'Lac Bernard • Wakefield, Quebec',
    joinRenew: 'Join or Renew Membership',
    learnMore: 'Learn More',
    becomeMember: 'Become a Member Today',
    whatWeDo: 'What we do',
    whatWeDoDesc: 'Our dedicated volunteers work year-round to preserve the natural beauty and health of Lac Bernard for future generations.',
    safeguard: 'Safeguard the Environment',
    safeguardDesc: 'Regular water testing, invasive species control, and shoreline protection initiatives to maintain our lake\'s pristine condition.',
    build: 'Build Community',
    buildDesc: 'Organizing events, coordinating volunteers, and providing seasonal updates to keep our community connected and informed.',
    promote: 'Promote Safety',
    promoteDesc: 'Maintaining navigation buoys, communicating with municipalities, and ensuring safe recreational activities on the lake.',
    joinRenewTitle: 'Join or Renew',
    joinRenewDesc: 'Support the lake for just $75/year. Multi-year discounts available for long-term supporters.',
    joinNow: 'Join Now',
    milfoilTitle: 'Milfoil & Environment',
    milfoilDesc: '12% of the lake is now affected by invasive milfoil. Learn what you can do to help protect our waters.',
    aboutMilfoil: 'About Milfoil',
    volunteer: 'Volunteer',
    eventsTitle: 'Events & Regatta',
    eventsDesc: 'Join us for annual celebrations, the famous regatta, and social events that bring our community together.',
    seeEvents: 'See Events',
    impact: 'Our Impact',
    years: 'Years of Service',
    members: 'Active Members',
    events: 'Annual Events',
    volunteerRun: 'Volunteer Run',
    landAck: 'Land Acknowledgment',
    landAckText: 'The Association would like to acknowledge that the land on which we gather is the traditional unceded territory of the Anishinaabeg People.',
    latestNews: 'Latest News',
    readMore: 'Read more',
  },
  fr: {
    site: 'Association du lac Bernard',
    hero: frontmatter?.heroTitle ?? 'Bienvenue à l\'Association du lac Bernard',
    subtitle: frontmatter?.heroSubtitle ?? '',
    kicker: 'Lac Bernard • Wakefield, Québec',
    joinRenew: 'Adhérer ou renouveler',
    learnMore: 'En savoir plus',
    becomeMember: 'Devenez membre aujourd\'hui',
    whatWeDo: 'Ce que nous faisons',
    whatWeDoDesc: 'Nos bénévoles dévoués travaillent toute l\'année pour préserver la beauté naturelle et la santé du lac Bernard pour les générations futures.',
    safeguard: 'Protéger l\'environnement',
    safeguardDesc: 'Tests d\'eau réguliers, contrôle des espèces envahissantes et initiatives de protection du rivage pour maintenir l\'état vierge de notre lac.',
    build: 'Construire la communauté',
    buildDesc: 'Organiser des événements, coordonner les bénévoles et fournir des mises à jour saisonnières pour garder notre communauté connectée et informée.',
    promote: 'Promouvoir la sécurité',
    promoteDesc: 'Maintenir les bouées de navigation, communiquer avec les municipalités et assurer des activités récréatives sécuritaires sur le lac.',
    joinRenewTitle: 'Adhérer ou renouveler',
    joinRenewDesc: 'Soutenez le lac pour seulement 75 $/an. Des rabais pluriannuels sont disponibles pour les partisans à long terme.',
    joinNow: 'Adhérer maintenant',
    milfoilTitle: 'Myriophylle et environnement',
    milfoilDesc: '12 % du lac est maintenant affecté par le myriophylle envahissant. Découvrez ce que vous pouvez faire pour aider à protéger nos eaux.',
    aboutMilfoil: 'À propos du myriophylle',
    volunteer: 'Bénévole',
    eventsTitle: 'Événements et régate',
    eventsDesc: 'Rejoignez-nous pour les célébrations annuelles, la célèbre régate et les événements sociaux qui rassemblent notre communauté.',
    seeEvents: 'Voir les événements',
    impact: 'Notre impact',
    years: 'Années de service',
    members: 'Membres actifs',
    events: 'Événements annuels',
    volunteerRun: 'Géré par des bénévoles',
    landAck: 'Reconnaissance du territoire',
    landAckText: 'L\'Association souhaite reconnaître que le territoire sur lequel nous nous rassemblons est le territoire traditionnel non cédé du peuple Anishinaabeg.',
    latestNews: 'Dernières nouvelles',
    readMore: 'Lire la suite',
  },
};

const t = titles[currentLang];
const title = t.site;
const heroTitle = t.hero;
const heroSubtitle = t.subtitle;
---

<html lang={currentLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta
      name="description"
      content="Join the Lac Bernard Association - a volunteer-run organization dedicated to protecting our lake, building community, and promoting safety since 1979."
    />
  </head>

  <body>
    <SiteHeader />

    <main id="main-content">
      <section class="hero" aria-label="Homepage hero">
        <div class="container heroInner">
          <div class="heroCopy">
            <h1>{heroTitle}</h1>
            {heroSubtitle && <p class="subtitle" set:html={heroSubtitle} />}
          </div>
        </div>
      </section>

      <section class="section">
        <div class="container prose">
          <Content />
        </div>
      </section>

      {latestPost && (
        <section class="section">
          <div class="container">
            <h2>{t.latestNews}</h2>
            <ul class="newsList">
              <li>
                <a href={`/en/news/${latestPost.id}/`}>
                  <h3>{latestPost.data.title}</h3>
                  <div class="newsDate">
                    <FormattedDate date={latestPost.data.pubDate} lang={currentLang} />
                  </div>
                  <p class="excerpt">
                    {latestPost.data.description}
                    {' '}
                    <span class="readMore">{t.readMore}: {latestPost.data.title}</span>
                  </p>
                </a>
              </li>
            </ul>
          </div>
        </section>
      )}

      <section class="section stats">
        <div class="container">
          <h2>{t.impact}</h2>
          <div class="statsGrid">
            <div class="stat"><div class="num">92</div><div class="label">{t.years}</div></div>
            <div class="stat"><div class="num">200+</div><div class="label">{t.members}</div></div>
            <div class="stat"><div class="num">3+</div><div class="label">{t.events}</div></div>
            <div class="stat"><div class="num">100%</div><div class="label">{t.volunteerRun}</div></div>
          </div>
        </div>
      </section>

      <section class="section land">
        <div class="container">
          <h2>{t.landAck}</h2>
          <p>{t.landAckText}</p>
        </div>
      </section>
    </main>

    <SiteFooter />

    <style>
      /* Page-specific styles for homepage */
      .hero {
        padding: 72px 0 var(--spacing-section);
        position: relative;
        background-image: url('/images/mirrorlake_jeffstubbins-2.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        color: white;
      }
      
      .hero::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        z-index: 0;
      }
      
      .hero .container {
        position: relative;
        z-index: 1;
      }
      
      .heroInner {
        display: block;
      }
      
      .heroCopy {
        color: white;
      }
      
      .kicker {
        margin: 0 0 12px;
        color: rgba(255, 255, 255, 0.8);
        font-size: 16px;
        letter-spacing: .14em;
        text-transform: uppercase;
      }
      
      .hero h1 {
        margin: 0 0 18px;
        font-size: clamp(40px, 5vw, 64px);
        line-height: 1.06;
        letter-spacing: -.03em;
        color: white;
      }
      
      .hero .subtitle {
        margin: 0 0 22px;
        color: rgba(255, 255, 255, 0.9);
        font-size: 19px;
      }
      
      .prose .btnPrimary {
        margin-top: 20px;
        display: inline-block;
      }
      
      .land {
        background: rgba(0,0,0,.03);
        text-align: center;
      }
      
      .land h2 {
        font-size: 28px;
      }
      
      .land p {
        color: var(--muted);
        font-size: 19px;
        max-width: 75ch;
        margin: 0 auto;
      }
      
      .newsList {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      
      .newsList li {
        margin: 0;
      }
      
      .newsList a {
        display: block;
        text-decoration: none;
        color: inherit;
        padding: 20px 0;
        border-bottom: 1px solid var(--border);
      }
      
      .newsList a:hover {
        color: var(--accent);
      }
      
      .newsList h3 {
        margin: 0 0 8px;
        font-size: 24px;
        font-weight: 600;
      }
      
      .newsList .newsDate {
        display: block;
        color: var(--muted);
        font-size: 14px;
        margin-bottom: 12px;
      }
      
      .newsList .newsDate time {
        color: inherit;
      }
      
      .newsList .excerpt {
        margin: 0;
        color: var(--text);
        line-height: 1.6;
      }
      
      .newsList .readMore {
        color: var(--accent);
        font-weight: 500;
      }
      
      @media (max-width: 920px) {
        .heroInner {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </body>
</html>