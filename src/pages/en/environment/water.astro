---
import Page from '../../../layouts/Page.astro';

const [page] = await Astro.glob('../../../../content/pages/en/environment-water.md');
if (!page) throw new Error('Missing content/pages/en/environment-water.md');

const title = page.frontmatter?.title || 'Protecting Our Water';
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="environment" />
