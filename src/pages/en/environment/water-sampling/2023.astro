---
import Page from '@/layouts/Page.astro';
import { loadContentPage } from '@/utils/loadContentPage';

const page = await loadContentPage('en', 'environment-water-sampling-2023');
const title = page.frontmatter?.title ?? "Report on Water Quality Sampling 2023";
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="environment" />
