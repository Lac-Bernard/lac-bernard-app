---
import Page from '../../../../layouts/Page.astro';
import { type Language } from '../../../../utils/i18n';

const currentPath = Astro.url.pathname;
const currentLang = (Astro.currentLocale || 'en') as Language;

const [page] = currentLang === 'fr' 
  ? await Astro.glob('../../../../../content/pages/fr/environment-water-sampling-1986.md')
  : await Astro.glob('../../../../../content/pages/environment-water-sampling-1986.md');
if (!page) throw new Error(`Missing content/pages/${currentLang === 'fr' ? 'fr/' : ''}environment-water-sampling-1986.md`);

const titles = {
  en: 'Water Quality Results – 1986',
  fr: 'Résultats de la qualité de l\'eau – 1986',
};

const title = page.frontmatter?.title || titles[currentLang];
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="environment" />
