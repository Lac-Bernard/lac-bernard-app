---
import Page from '@/layouts/Page.astro';
import { loadContentPage } from '@/utils/loadContentPage';

const page = await loadContentPage('en', 'history-newspaper-clippings');
const title = page.frontmatter?.title ?? "Newspaper Clippings Collection of Lac Bernard";
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="history" />
