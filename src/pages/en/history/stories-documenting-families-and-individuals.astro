---
import Page from '@/layouts/Page.astro';
import { loadContentPage } from '@/utils/loadContentPage';

const page = await loadContentPage('en', 'history-stories-families-individuals');
const title = page.frontmatter?.title ?? "Stories: Documenting Families and Individuals";
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="history" />
