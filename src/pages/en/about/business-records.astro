---
import Page from '@/layouts/Page.astro';
import DriveFolderBrowser from '@/components/DriveFolderBrowser.astro';
import { loadContentPage } from '@/utils/loadContentPage';

const page = await loadContentPage('en', 'about-business-records');
const title = page.frontmatter?.title ?? "Recent Business Records";
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="about">
  <div slot="extra">
    <DriveFolderBrowser rootFolderId="1dBOjaQn37pO5-445XgENTO4VHI620ozB" locale="en" />
  </div>
</Page>
