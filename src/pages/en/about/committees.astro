---
import Page from '../../../layouts/Page.astro';
import { type Language } from '../../../utils/i18n';

const currentPath = Astro.url.pathname;
const currentLang = (Astro.currentLocale || 'en') as Language;

const [page] = currentLang === 'fr' 
  ? await Astro.glob('../../../../content/pages/fr/about-committees.md')
  : await Astro.glob('../../../../content/pages/en/about-committees.md');
if (!page) throw new Error(`Missing content/pages/${currentLang === 'fr' ? 'fr/' : 'en/'}about-committees.md`);

const titles = {
  en: 'Association Committees',
  fr: 'Comités de l\'Association',
};

const title = page.frontmatter?.title || titles[currentLang];
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="about" />
