---
import Page from '@/layouts/Page.astro';
import DriveFolderBrowser from '@/components/DriveFolderBrowser.astro';
import { loadContentPage } from '@/utils/loadContentPage';

const page = await loadContentPage('en', 'about-archive');
const title = page.frontmatter?.title ?? "Archive Portal";
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="about">
  <div slot="extra">
    <DriveFolderBrowser rootFolderId="1FymO4jIrA_Xa4a2mwRo-UnTsWZQOOOCf" locale="en" />
  </div>
</Page>
