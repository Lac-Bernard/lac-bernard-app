---
import Page from '../../../layouts/Page.astro';
import { type Language } from '../../../utils/i18n';

const currentPath = Astro.url.pathname;
const currentLang = (Astro.currentLocale || 'en') as Language;

const [page] = currentLang === 'fr' 
  ? await Astro.glob('../../../../content/pages/fr/about-bylaws.md')
  : await Astro.glob('../../../../content/pages/about-bylaws.md');
if (!page) throw new Error(`Missing content/pages/${currentLang === 'fr' ? 'fr/' : ''}about-bylaws.md`);

const titles = {
  en: 'Association Bylaws',
  fr: 'Règlements de l\'Association',
};

const title = page.frontmatter?.title || titles[currentLang];
const description = page.frontmatter?.description;

const pdfFallbackText = currentLang === 'fr' 
  ? 'Votre navigateur ne peut pas afficher les PDF. ' 
  : 'Your browser cannot display PDFs. ';
const pdfDownloadText = currentLang === 'fr' 
  ? 'Télécharger les règlements' 
  : 'Download the bylaws';
const pdfTitle = currentLang === 'fr' ? 'Règlements de 2025' : '2025 Bylaws';
---

<Page title={title} description={description} content={page} section="about">
  <div slot="extra" class="pdf-embed-container">
    <iframe 
      src="/documents/2025-05-21-bylaws.pdf" 
      type="application/pdf"
      class="pdf-embed"
      title={pdfTitle}
    >
      <p>
        {pdfFallbackText}
        <a href="/documents/2025-05-21-bylaws.pdf">
          {pdfDownloadText}
        </a>
      </p>
    </iframe>
  </div>
</Page>

<style>
  .pdf-embed-container {
    margin-top: 2em;
    width: 100%;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
  }

  .pdf-embed {
    width: 100%;
    height: 800px;
    border: none;
    display: block;
  }

  @media (max-width: 920px) {
    .pdf-embed {
      height: 600px;
    }
  }
</style>
