---
import Page from '../../../layouts/Page.astro';

const [page] = await Astro.glob('../../../../content/pages/en/about-bylaws.md');
if (!page) throw new Error('Missing content/pages/en/about-bylaws.md');

const title = page.frontmatter?.title || 'Association Bylaws';
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="about">
  <div slot="extra" class="pdf-embed-container">
    <iframe 
      src="/documents/bylaws/en.pdf" 
      type="application/pdf"
      class="pdf-embed"
      title="2026 Bylaws"
    >
      <p>
        Your browser cannot display PDFs. 
        <a href="/documents/bylaws/en.pdf">
          Download the bylaws
        </a>
      </p>
    </iframe>
  </div>
</Page>

<style>
  .pdf-embed-container {
    margin-top: 2em;
    width: 100%;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
  }

  .pdf-embed {
    width: 100%;
    height: 800px;
    border: none;
    display: block;
  }

  @media (max-width: 920px) {
    .pdf-embed {
      height: 600px;
    }
  }
</style>
