---
import Page from '../../layouts/Page.astro';
import { type Language } from '../../utils/i18n';

const currentPath = Astro.url.pathname;
const currentLang = (Astro.currentLocale || 'fr') as Language;

const [page] = await Astro.glob('../../../content/pages/fr/about-business-records.md');
if (!page) throw new Error('Missing content/pages/fr/about-business-records.md');

const titles: Record<Language, string> = {
  fr: 'Procès-verbaux récents',
  en: 'Recent Business Records',
};

const title = page.frontmatter?.title || titles[currentLang];
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="about" />
