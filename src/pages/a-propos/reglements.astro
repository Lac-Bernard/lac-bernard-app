---
import Page from '../../layouts/Page.astro';
import { type Language } from '../../utils/i18n';

const currentPath = Astro.url.pathname;
const currentLang = (Astro.currentLocale || 'fr') as Language;

const [page] = await Astro.glob('../../../content/pages/fr/about-bylaws.md');
if (!page) throw new Error('Missing content/pages/fr/about-bylaws.md');

const titles = {
  fr: 'Règlements de l\'Association',
};

const title = page.frontmatter?.title || titles[currentLang];
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="about">
  <div slot="extra" class="pdf-embed-container">
    <iframe 
      src="/documents/2026-05-bylaws/bylaws-french.pdf" 
      type="application/pdf"
      class="pdf-embed"
      title="Règlements de 2026"
    >
      <p>
        Votre navigateur ne peut pas afficher les PDF. 
        <a href="/documents/2026-05-bylaws/bylaws-french.pdf">
          Télécharger les règlements
        </a>
      </p>
    </iframe>
  </div>
</Page>

<style>
  .pdf-embed-container {
    margin-top: 2em;
    width: 100%;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
  }

  .pdf-embed {
    width: 100%;
    height: 800px;
    border: none;
    display: block;
  }

  @media (max-width: 920px) {
    .pdf-embed {
      height: 600px;
    }
  }
</style>
