---
import Page from '../layouts/Page.astro';

const [page] = await Astro.glob('../../content/pages/community.md');
if (!page) throw new Error('Missing content/pages/community.md');

const title = page.frontmatter?.title || 'Community';
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="community" />
