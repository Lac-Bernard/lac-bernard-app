---
import Page from '../../layouts/Page.astro';

const [page] = await Astro.glob('../../../content/pages/about-business-records.md');
if (!page) throw new Error('Missing content/pages/about-business-records.md');

const title = page.frontmatter?.title || 'Recent Business Records';
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="about" />
