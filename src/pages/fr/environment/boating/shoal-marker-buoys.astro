---
import Page from '../../../../layouts/Page.astro';

const [page] = await Astro.glob('../../../../../content/pages/en/environment-boating-shoal-marker-buoys.md');
if (!page) throw new Error('Missing content/pages/en/environment-boating-shoal-marker-buoys.md');

const title = page.frontmatter?.title || 'Shoal Marker Buoys';
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="environment" />
