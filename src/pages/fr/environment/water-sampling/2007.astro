---
import Page from '@/layouts/Page.astro';
import { loadContentPage } from '@/utils/loadContentPage';

const page = await loadContentPage('fr', 'environment-water-sampling-2007');
const title = page.frontmatter?.title ?? "Résultats de la qualité de l'eau – 2007";
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="environment" />
