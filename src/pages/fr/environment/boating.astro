---
import Page from '@/layouts/Page.astro';
import { loadContentPage } from '@/utils/loadContentPage';

const page = await loadContentPage('fr', 'environment-boating');
const title = page.frontmatter?.title ?? "Boating on Lac Bernard";
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="environment" />
