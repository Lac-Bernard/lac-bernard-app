---
export const prerender = false;

import AdminMembershipView from '../../../components/members/AdminMembershipView.astro';
import { createSupabasePageClient } from '../../../lib/supabase/server';
import { isAppAdmin } from '../../../lib/auth/admin';
import { memberPaths } from '../../../lib/members/i18n';

const paths = memberPaths.fr;
const { supabase, flushCookies, redirectWithCookies } = createSupabasePageClient(
	Astro.request,
	Astro.cookies,
);
const {
	data: { user },
	error,
} = await supabase.auth.getUser();

if (error || !user) {
	return redirectWithCookies(`${paths.signIn}?next=${encodeURIComponent(paths.admin)}`);
}

if (!isAppAdmin(user)) {
	return redirectWithCookies(paths.account);
}

flushCookies();
const email = user.email ?? '';
---

<AdminMembershipView locale="fr" email={email} />
