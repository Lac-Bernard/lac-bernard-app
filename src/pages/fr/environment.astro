---
import Page from '@/layouts/Page.astro';
import DriveFolderBrowser from '@/components/DriveFolderBrowser.astro';
import { loadContentPage } from '@/utils/loadContentPage';

const page = await loadContentPage('fr', 'environment');
const title = page.frontmatter?.title ?? "Environnement";
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="environment">
  <div slot="extra">
    <DriveFolderBrowser rootFolderId="1pLhabTA7ZbPmijuT2lexmZd8AmXvjcyY" locale="fr" />
  </div>
</Page>
