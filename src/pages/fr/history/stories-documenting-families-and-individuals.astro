---
import Page from '@/layouts/Page.astro';
import DriveFolderBrowser from '@/components/DriveFolderBrowser.astro';
import { loadContentPage } from '@/utils/loadContentPage';

const page = await loadContentPage('fr', 'history-stories-families-individuals');
const title = page.frontmatter?.title ?? "Récits: Documentation des familles et individus";
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="history">
  <div slot="extra">
    <DriveFolderBrowser rootFolderId="1Qyt1NhiFtAsG6GDGsnNpAJVCd2j9xhKO" locale="fr" />
  </div>
</Page>
