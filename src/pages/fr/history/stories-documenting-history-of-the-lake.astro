---
import Page from '@/layouts/Page.astro';
import DriveFolderBrowser from '@/components/DriveFolderBrowser.astro';
import { loadContentPage } from '@/utils/loadContentPage';

const page = await loadContentPage('fr', 'history-stories-lake');
const title = page.frontmatter?.title ?? "Récits: Documentation de l'histoire du lac";
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="history">
  <div slot="extra">
    <DriveFolderBrowser rootFolderId="1PCGcVBZKJeH85ZxhxCfN6e10ahMyLLkQ" locale="fr" />
  </div>
</Page>
