---
import Page from '@/layouts/Page.astro';
import { loadContentPage } from '@/utils/loadContentPage';

const page = await loadContentPage('fr', 'history-newspaper-clippings');
const title = page.frontmatter?.title ?? "Collection de coupures de journaux du lac Bernard";
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="history" />
