---
import Page from '@/layouts/Page.astro';
import DriveFolderBrowser from '@/components/DriveFolderBrowser.astro';
import { loadContentPage } from '@/utils/loadContentPage';

const page = await loadContentPage('fr', 'history-aerial-photos');
const title = page.frontmatter?.title ?? "Photos aériennes";
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="history">
  <div slot="extra">
    <DriveFolderBrowser rootFolderId="15WIENErk_jkIySJZqj03iD0seiTWZhr8" locale="fr" />
  </div>
</Page>
