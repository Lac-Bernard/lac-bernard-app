---
import Page from '@/layouts/Page.astro';
import DriveFolderBrowser from '@/components/DriveFolderBrowser.astro';
import { loadContentPage } from '@/utils/loadContentPage';

const page = await loadContentPage('fr', 'history-fishing-club');
const title = page.frontmatter?.title ?? "Club de pêche";
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="history">
  <div slot="extra">
    <DriveFolderBrowser rootFolderId="16B4B3NZNexzG19UoOyj5U04sGC7cPGle" locale="fr" />
  </div>
</Page>
