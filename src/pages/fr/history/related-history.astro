---
import Page from '@/layouts/Page.astro';
import DriveFolderBrowser from '@/components/DriveFolderBrowser.astro';
import { loadContentPage } from '@/utils/loadContentPage';

const page = await loadContentPage('fr', 'history-related');
const title = page.frontmatter?.title ?? "Histoire connexe";
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="history">
  <div slot="extra">
    <DriveFolderBrowser rootFolderId="1C8fEITRmoRj7GvovkUqguFSxcNYGFpw-" locale="fr" />
  </div>
</Page>
