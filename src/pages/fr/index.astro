---
import '../../styles/theme.css';
import '../../styles/components.css';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { getLocalizedHref, type Language } from '../../utils/i18n';

const currentLang = (Astro.currentLocale || 'fr') as Language;

// Load content based on language
const [home] = await Astro.glob('../../../content/pages/fr/home.md');
if (!home) throw new Error('Missing content/pages/fr/home.md');

const { Content, frontmatter } = home;

const titles = {
  fr: {
    site: 'Association du lac Bernard',
    hero: frontmatter?.heroTitle ?? 'Bienvenue à l\'Association du lac Bernard',
    subtitle: frontmatter?.heroSubtitle ?? '',
    kicker: 'Lac Bernard • Wakefield, Québec',
    joinRenew: 'Adhérer ou renouveler',
    learnMore: 'En savoir plus',
    whatWeDo: 'Ce que nous faisons',
    whatWeDoDesc: 'Nos bénévoles dévoués travaillent toute l\'année pour préserver la beauté naturelle et la santé du lac Bernard pour les générations futures.',
    safeguard: 'Protéger l\'environnement',
    safeguardDesc: 'Tests d\'eau réguliers, contrôle des espèces envahissantes et initiatives de protection du rivage pour maintenir l\'état vierge de notre lac.',
    build: 'Construire la communauté',
    buildDesc: 'Organiser des événements, coordonner les bénévoles et fournir des mises à jour saisonnières pour garder notre communauté connectée et informée.',
    promote: 'Promouvoir la sécurité',
    promoteDesc: 'Maintenir les bouées de navigation, communiquer avec les municipalités et assurer des activités récréatives sécuritaires sur le lac.',
    joinRenewTitle: 'Adhérer ou renouveler',
    joinRenewDesc: 'Soutenez le lac pour seulement 75 $/an. Des rabais pluriannuels sont disponibles pour les partisans à long terme.',
    joinNow: 'Adhérer maintenant',
    milfoilTitle: 'Myriophylle et environnement',
    milfoilDesc: '12 % du lac est maintenant affecté par le myriophylle envahissant. Découvrez ce que vous pouvez faire pour aider à protéger nos eaux.',
    aboutMilfoil: 'À propos du myriophylle',
    volunteer: 'Bénévole',
    eventsTitle: 'Événements et régate',
    eventsDesc: 'Rejoignez-nous pour les célébrations annuelles, la célèbre régate et les événements sociaux qui rassemblent notre communauté.',
    seeEvents: 'Voir les événements',
    impact: 'Notre impact',
    years: 'Années de service',
    members: 'Membres actifs',
    events: 'Événements annuels',
    volunteerRun: 'Géré par des bénévoles',
    landAck: 'Reconnaissance du territoire',
    landAckText: 'L\'Association souhaite reconnaître que le territoire sur lequel nous nous rassemblons est le territoire traditionnel non cédé du peuple Anishinaabeg.',
  },
};

const t = titles[currentLang];
const title = t.site;
const heroTitle = t.hero;
const heroSubtitle = t.subtitle;
---

<html lang={currentLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta
      name="description"
      content="Rejoignez l'Association du lac Bernard - une organisation gérée par des bénévoles dédiée à la protection de notre lac, à la construction de la communauté et à la promotion de la sécurité depuis 1979."
    />
  </head>

  <body>
    <SiteHeader />

    <main id="main-content">
      <section class="hero" aria-label="Hero de la page d'accueil">
        <div class="container heroInner">
          <div class="heroCopy">
            <p class="kicker">{t.kicker}</p>
            <h1>{heroTitle}</h1>
            {heroSubtitle && <p class="subtitle" set:html={heroSubtitle} />}

            <div class="heroButtons">
              <a class="btnPrimary" href={getLocalizedHref('/membership', currentLang)}>{t.joinRenew}</a>
              <a class="btnGhost" href={getLocalizedHref('/about', currentLang)}>{t.learnMore}</a>
            </div>
          </div>

          <aside class="heroPanel" aria-label="Actions rapides">
            <h2>{t.whatWeDo}</h2>
            <p class="muted">
              {t.whatWeDoDesc}
            </p>

            <div class="cards">
              <article class="card">
                <div class="icon">🌊</div>
                <h3>{t.safeguard}</h3>
                <p>{t.safeguardDesc}</p>
                <a href={getLocalizedHref('/environment', currentLang)}>{t.learnMore} →</a>
              </article>

              <article class="card">
                <div class="icon">🤝</div>
                <h3>{t.build}</h3>
                <p>{t.buildDesc}</p>
                <a href={getLocalizedHref('/community', currentLang)}>{t.learnMore} →</a>
              </article>

              <article class="card">
                <div class="icon">🛡️</div>
                <h3>{t.promote}</h3>
                <p>{t.promoteDesc}</p>
                <a href={getLocalizedHref('/safety', currentLang)}>{t.learnMore} →</a>
              </article>
            </div>
          </aside>
        </div>
      </section>

      <section class="section">
        <div class="container prose">
          <Content />
        </div>
      </section>

      <section class="section alt">
        <div class="container ctaRow">
          <div class="cta">
            <h2>{t.joinRenewTitle}</h2>
            <p>{t.joinRenewDesc}</p>
            <a class="btnPrimary" href={getLocalizedHref('/membership', currentLang)}>{t.joinNow}</a>
          </div>

          <div class="cta">
            <h2>{t.milfoilTitle}</h2>
            <p><strong>{t.milfoilDesc}</strong></p>
            <div class="ctaButtons">
              <a class="btnPrimary" href={getLocalizedHref('/environment/milfoil', currentLang)}>{t.aboutMilfoil}</a>
              <a class="btnGhost" href={getLocalizedHref('/volunteer', currentLang)}>{t.volunteer}</a>
            </div>
          </div>

          <div class="cta">
            <h2>{t.eventsTitle}</h2>
            <p>{t.eventsDesc}</p>
            <a class="btnPrimary" href={getLocalizedHref('/events', currentLang)}>{t.seeEvents}</a>
          </div>
        </div>
      </section>

      <section class="section stats">
        <div class="container">
          <h2>{t.impact}</h2>
          <div class="statsGrid">
            <div class="stat"><div class="num">92</div><div class="label">{t.years}</div></div>
            <div class="stat"><div class="num">200+</div><div class="label">{t.members}</div></div>
            <div class="stat"><div class="num">12</div><div class="label">{t.events}</div></div>
            <div class="stat"><div class="num">100%</div><div class="label">{t.volunteerRun}</div></div>
          </div>
        </div>
      </section>

      <section class="section land">
        <div class="container">
          <h2>{t.landAck}</h2>
          <p>{t.landAckText}</p>
        </div>
      </section>
    </main>

    <SiteFooter />

    <style>
      /* Page-specific styles for homepage */
      .hero {
        padding: 72px 0 var(--spacing-section);
      }
      
      .heroInner {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--spacing-section);
        align-items: start;
      }
      
      .heroCopy {
      }
      
      .kicker {
        margin: 0 0 12px;
        color: var(--muted);
        font-size: 16px;
        letter-spacing: .14em;
        text-transform: uppercase;
      }
      
      h1 {
        margin: 0 0 18px;
        font-size: clamp(40px, 5vw, 64px);
        line-height: 1.06;
        letter-spacing: -.03em;
      }
      
      .subtitle {
        margin: 0 0 22px;
        color: var(--muted);
        font-size: 19px;
      }
      
      .heroButtons {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }
      
      .heroPanel {
        border: 1px solid var(--border);
        background: rgba(255,255,255,.95);
        border-radius: 22px;
        box-shadow: var(--shadow);
        padding: 20px;
      }
      
      .heroPanel h2 {
        margin: 0 0 10px;
        font-size: 20px;
        letter-spacing: -.01em;
      }
      
      .heroPanel .muted {
        margin: 0 0 20px;
        font-size: 17px;
        line-height: 1.4;
      }
      
      .land {
        background: rgba(0,0,0,.03);
        text-align: center;
      }
      
      .land h2 {
        font-size: 28px;
      }
      
      .land p {
        color: var(--muted);
        font-size: 19px;
        max-width: 75ch;
        margin: 0 auto;
      }
      
      @media (max-width: 920px) {
        .heroInner {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </body>
</html>
