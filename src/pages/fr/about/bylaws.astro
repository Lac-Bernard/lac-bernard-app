---
import Page from '@/layouts/Page.astro';
import { loadContentPage } from '@/utils/loadContentPage';

const page = await loadContentPage('fr', 'about-bylaws');
const title = page.frontmatter?.title ?? "Règlements de l'Association";
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="about">
  <div slot="extra" class="pdf-embed-container">
    <iframe
      src="/documents/bylaws/fr.pdf"
      type="application/pdf"
      class="pdf-embed"
      title="Règlements de 2026"
    >
      <p>
        Votre navigateur ne peut pas afficher les PDF.
        <a href="/documents/bylaws/fr.pdf">Télécharger les règlements</a>
      </p>
    </iframe>
  </div>
</Page>

<style>
  .pdf-embed-container {
    margin-top: 2em;
    width: 100%;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
  }

  .pdf-embed {
    width: 100%;
    height: 800px;
    border: none;
    display: block;
  }

  @media (max-width: 920px) {
    .pdf-embed {
      height: 600px;
    }
  }
</style>
