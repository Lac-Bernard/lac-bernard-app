---
import Page from '../../../../layouts/Page.astro';
import { type Language } from '../../../../utils/i18n';

const currentPath = Astro.url.pathname;
const currentLang = (Astro.currentLocale || 'fr') as Language;

const [page] = await Astro.glob('../../../../content/pages/fr/environment-water-sampling-2008.md');
if (!page) throw new Error('Missing content/pages/fr/environment-water-sampling-2008.md');

const titles: Record<Language, string> = {
  fr: 'Résultats de la qualité de l\'eau – 2008',
  en: 'Water Quality Results – 2008',
};

const title = page.frontmatter?.title || titles[currentLang];
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="environment" />
