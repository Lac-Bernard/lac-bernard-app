---
import type { Language } from '@/utils/i18n';
import { getCollection, render } from 'astro:content';
import BlogPost from '@/layouts/BlogPost.astro';
import { blogCollectionId, blogPostSlug } from '@/utils/blog';

const locales: Language[] = ['en', 'fr'];

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return locales.flatMap((lang) =>
		posts
			.filter((post) => post.id.startsWith(`${lang}/`))
			.map((post) => ({
				params: {
					lang,
					slug: blogPostSlug(post.id),
				},
			})),
	);
}

const lang = Astro.params.lang as Language;
if (lang !== 'en' && lang !== 'fr') {
	throw new Error(`Invalid language: ${Astro.params.lang}`);
}

const raw = Astro.params.slug;
const slugPath = Array.isArray(raw) ? raw.join('/') : (raw ?? '');
if (!slugPath) {
	throw new Error('Slug parameter is missing');
}

const posts = await getCollection('blog');
const post = posts.find((p) => p.id === blogCollectionId(lang, slugPath));

if (!post) {
	throw new Error(`Post not found for slug: ${slugPath}`);
}

if (!post.data) {
	throw new Error(`Post data is missing for post: ${post.id}`);
}

if (!post.data.pubDate) {
	throw new Error(
		`pubDate is missing for post: ${post.id}. Available keys: ${Object.keys(post.data).join(', ')}`,
	);
}

const { Content } = await render(post);
---

<BlogPost
	title={post.data.title}
	description={post.data.description}
	pubDate={post.data.pubDate}
	updatedDate={post.data.updatedDate}
	heroImage={post.data.heroImage}
	currentPostId={post.id}
>
	<Content />
</BlogPost>
