---
import Page from '../layouts/Page.astro';

const [page] = await Astro.glob('../../content/pages/about.md');
if (!page) throw new Error('Missing content/pages/about.md');

const title = page.frontmatter?.title || 'About the Association';
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="about" />
