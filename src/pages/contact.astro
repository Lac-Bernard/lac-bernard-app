---
import Page from '../layouts/Page.astro';

const [page] = await Astro.glob('../../content/pages/contact.md');
if (!page) throw new Error('Missing content/pages/contact.md');

const title = page.frontmatter?.title || 'Contact Us';
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} />
