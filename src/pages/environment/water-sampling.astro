---
import Page from '../../layouts/Page.astro';

const [page] = await Astro.glob('../../../content/pages/environment-water-sampling.md');
if (!page) throw new Error('Missing content/pages/environment-water-sampling.md');

const title = page.frontmatter?.title || 'Water Sampling Program';
const description = page.frontmatter?.description;
---

<Page title={title} description={description} content={page} section="environment" />
