---
import '../styles/theme.css';
import '../styles/components.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { getLocalizedHref, type Language } from '../utils/i18n';

interface NavItem {
  href: string;
  label: string;
  children?: NavItem[];
}

interface Props {
  title: string;
  description?: string;
  content?: any;
  section?: 'about' | 'environment' | 'community' | 'history';
}

const { title, description, content, section } = Astro.props;
const { Content } = content || {};

const currentPath = Astro.url.pathname;
const currentLang = (Astro.currentLocale || 'fr') as Language;

// Define navigation items for each section
const aboutNav: { en: NavItem[]; fr: NavItem[] } = {
  en: [
    { href: '/en/about', label: 'About the Association' },
    { href: '/en/about/executive', label: 'Association Executive' },
    { href: '/en/about/committees', label: 'Association Committees' },
    { href: '/en/about/bylaws', label: 'Association Bylaws' },
    { href: '/en/about/business-records', label: 'Recent Business Records' },
    { href: '/en/about/archive', label: 'Archive Portal' },
  ],
  fr: [
    { href: '/a-propos', label: 'À propos de l\'Association' },
    { href: '/a-propos/comite-executif', label: 'Comité exécutif' },
    { href: '/a-propos/comites', label: 'Comités de l\'Association' },
    { href: '/a-propos/reglements', label: 'Règlements de l\'Association' },
    { href: '/a-propos/proces-verbaux', label: 'Procès-verbaux récents' },
    { href: '/a-propos/archives', label: 'Portail d\'archives' },
  ],
};

const environmentNav: { en: NavItem[]; fr: NavItem[] } = {
  en: [
    { href: '/en/environment', label: 'Environment' },
    { href: '/en/environment/water-sampling', label: 'Water Sampling Program' },
    { href: '/en/environment/milfoil', label: 'Eurasian Milfoil' },
    { href: '/en/environment/shoreline', label: 'Protecting Our Shoreline' },
    { href: '/en/environment/water', label: 'Protecting Our Water' },
    { href: '/en/environment/boating', label: 'Boating on Lac Bernard' },
    { href: '/en/environment/wildlife', label: 'Lake Wildlife' },
  ],
  fr: [
    { href: '/environnement', label: 'Environnement' },
    { href: '/environnement/echantillonnage-eau', label: 'Programme d\'échantillonnage de l\'eau' },
    { href: '/environnement/myriophylle', label: 'Myriophylle à épi' },
    { href: '/environnement/rivage', label: 'Protéger notre rivage' },
    { href: '/environnement/eau', label: 'Protéger notre eau' },
    { href: '/environnement/navigation', label: 'Navigation sur le lac Bernard' },
    { href: '/environnement/faune', label: 'Faune du lac' },
  ],
};

const historyNav: { en: NavItem[]; fr: NavItem[] } = {
  en: [
    { href: '/en/history', label: 'History' },
    { href: '/en/history/first-nations', label: 'First Nations' },
    { href: '/en/history/fishing-club', label: 'Fishing Club' },
    { href: '/en/history/maps', label: 'Maps' },
    { href: '/en/history/ariel-photos', label: 'Ariel Photos' },
    { href: '/en/history/stories-documenting-families-and-individuals', label: 'Stories: Documenting Families and Individuals' },
    { href: '/en/history/stories-documenting-history-of-the-lake', label: 'Stories: Documenting History of the Lake' },
    { href: '/en/history/newspaper-clippings-collection-of-lac-bernard', label: 'Newspaper Clippings Collection of Lac Bernard' },
    { href: '/en/history/historical-research-and-sources', label: 'Historical Research and Sources' },
    { href: '/en/history/properties-and-deeds', label: 'Properties and Deeds' },
    { href: '/en/history/related-history', label: 'Related History' },
  ],
  fr: [
    { href: '/histoire', label: 'Histoire' },
    { href: '/histoire/premieres-nations', label: 'Premières Nations' },
    { href: '/histoire/club-de-peche', label: 'Club de pêche' },
    { href: '/histoire/cartes', label: 'Cartes' },
    { href: '/histoire/photos-aeriennes', label: 'Photos aériennes' },
    { href: '/histoire/recits-familles-et-individus', label: 'Récits: Documentation des familles et individus' },
    { href: '/histoire/recits-histoire-du-lac', label: 'Récits: Documentation de l\'histoire du lac' },
    { href: '/histoire/collection-coupures-de-journaux-lac-bernard', label: 'Collection de coupures de journaux du lac Bernard' },
    { href: '/histoire/recherche-historique-et-sources', label: 'Recherche historique et sources' },
    { href: '/histoire/proprietes-et-titres', label: 'Propriétés et titres' },
    { href: '/histoire/histoire-connexe', label: 'Histoire connexe' },
  ],
};

const communityNav: { en: NavItem[]; fr: NavItem[] } = {
  en: [
    { href: '/en/community', label: 'Community' },
    { href: '/en/community/regatta', label: 'Annual Regatta' },
    { 
      href: '/en/community/security', 
      label: 'Security',
      children: [
        { href: '/en/community/security/police', label: 'Police' },
        { href: '/en/community/security/emergency-contacts', label: 'Emergency Contacts' },
        { href: '/en/community/security/fire', label: 'Fire' },
        { href: '/en/community/security/neighbourhood-watch', label: 'Neighbourhood Watch Program' },
      ]
    },
  ],
  fr: [
    { href: '/communaute', label: 'Communauté' },
    { href: '/communaute/regate', label: 'Régate annuelle' },
    { 
      href: '/communaute/securite', 
      label: 'Sécurité',
      children: [
        { href: '/communaute/securite/police', label: 'Police' },
        { href: '/communaute/securite/contacts-urgence', label: 'Contacts d\'urgence' },
        { href: '/communaute/securite/incendie', label: 'Incendie' },
        { href: '/communaute/securite/surveillance-quartier', label: 'Programme de surveillance de quartier' },
      ]
    },
  ],
};

// Select navigation based on section
const navItems = section === 'about' ? aboutNav[currentLang] : section === 'environment' ? environmentNav[currentLang] : section === 'history' ? historyNav[currentLang] : section === 'community' ? communityNav[currentLang] : null;
---

<html lang={currentLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Lac Bernard Association</title>
    <meta
      name="description"
      content={description || `Learn more about ${title} at the Lac Bernard Association.`}
    />
    <script async src="https://tally.so/widgets/embed.js"></script>
  </head>

  <body>
    <SiteHeader />

    <main id="main-content">
      <section class="section">
        <div class="container">
          {navItems ? (
            <div class="pageWithSidebar">
              <aside class="sidebar">
                <nav class="sidebarNav" aria-label="Section navigation">
                  {navItems?.map((item) => {
                    const normalizedHref = item.href.replace(/^\/(fr|en)(\/|$)/, '/');
                    const isActive = currentPath === item.href || currentPath === normalizedHref || currentPath === getLocalizedHref(normalizedHref, currentLang);
                    const hasChildren = item.children && item.children.length > 0;
                    // Always show children if they exist
                    const showChildren = hasChildren;
                    
                    return (
                      <div class="navItem">
                        <a 
                          href={getLocalizedHref(normalizedHref, currentLang)} 
                          class={isActive ? 'active' : ''}
                        >
                          {item.label}
                        </a>
                        {showChildren && item.children && (
                          <div class="navChildren">
                            {item.children.map((child) => {
                              const childNormalizedHref = child.href.replace(/^\/(fr|en)(\/|$)/, '/');
                              const isChildActive = currentPath === child.href || currentPath === childNormalizedHref || currentPath === getLocalizedHref(childNormalizedHref, currentLang);
                              return (
                                <a 
                                  href={getLocalizedHref(childNormalizedHref, currentLang)} 
                                  class={isChildActive ? 'active' : ''}
                                >
                                  {child.label}
                                </a>
                              );
                            })}
                          </div>
                        )}
                      </div>
                    );
                  })}
                </nav>
              </aside>
              <div class="pageContent prose">
                <h1>{title}</h1>
                {Content && <Content />}
                <slot name="extra" />
              </div>
            </div>
          ) : (
            <div class="prose">
              <h1>{title}</h1>
              {Content && <Content />}
              <slot name="extra" />
            </div>
          )}
        </div>
      </section>
    </main>

    <SiteFooter />
  </body>
</html>
