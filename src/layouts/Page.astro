---
import '../styles/theme.css';
import '../styles/components.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { siteUi } from '../i18n/site';
import { getLocalizedHref, languageFromAstro, type Language } from '../utils/i18n';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface NavItem {
  href: string;
  label: string;
  children?: NavItem[];
}

interface Props {
  title: string;
  description?: string;
  content?: any;
  section?: 'about' | 'environment' | 'community' | 'history';
}

const { title, description, content, section } = Astro.props;
const { Content } = content || {};

const currentPath = Astro.url.pathname;
const currentLang = languageFromAstro(Astro);
const site = siteUi[currentLang];

// Sidebar links: `href` is locale-agnostic (no `/en` or `/fr`). Labels differ per language.
// Rendering strips any accidental locale prefix, then `getLocalizedHref` adds the active locale.
const aboutNav: { en: NavItem[]; fr: NavItem[] } = {
  en: [
    { href: '/about', label: 'About the Association' },
    { href: '/about/executive', label: 'Association Executive' },
    { href: '/about/committees', label: 'Association Committees' },
    { href: '/about/bylaws', label: 'Association Bylaws' },
    { href: '/about/business-records', label: 'Recent Business Records' },
    { href: '/about/archive', label: 'Archive Portal' },
  ],
  fr: [
    { href: '/about', label: 'À propos de l\'Association' },
    { href: '/about/executive', label: 'Comité exécutif' },
    { href: '/about/committees', label: 'Comités de l\'Association' },
    { href: '/about/bylaws', label: 'Règlements de l\'Association' },
    { href: '/about/business-records', label: 'Procès-verbaux récents' },
    { href: '/about/archive', label: 'Portail d\'archives' },
  ],
};

const environmentNav: { en: NavItem[]; fr: NavItem[] } = {
  en: [
    { href: '/environment', label: 'Environment' },
    { href: '/environment/water-sampling', label: 'Water Sampling Program' },
    { href: '/environment/milfoil', label: 'Eurasian Milfoil' },
    { href: '/environment/shoreline', label: 'Protecting Our Shoreline' },
    { href: '/environment/water', label: 'Protecting Our Water' },
    { href: '/environment/boating', label: 'Boating on Lac Bernard' },
    { href: '/environment/wildlife', label: 'Lake Wildlife' },
  ],
  fr: [
    { href: '/environment', label: 'Environnement' },
    { href: '/environment/water-sampling', label: 'Programme d\'échantillonnage de l\'eau' },
    { href: '/environment/milfoil', label: 'Myriophylle à épi' },
    { href: '/environment/shoreline', label: 'Protéger notre rivage' },
    { href: '/environment/water', label: 'Protéger notre eau' },
    { href: '/environment/boating', label: 'Navigation sur le lac Bernard' },
    { href: '/environment/wildlife', label: 'Faune du lac' },
  ],
};

const historyNav: { en: NavItem[]; fr: NavItem[] } = {
  en: [
    { href: '/history', label: 'History' },
    { href: '/history/first-nations', label: 'First Nations' },
    { href: '/history/fishing-club', label: 'Fishing Club' },
    { href: '/history/maps', label: 'Maps' },
    { href: '/history/aerial-photos', label: 'Aerial Photos' },
    { href: '/history/stories-documenting-families-and-individuals', label: 'Stories: Documenting Families and Individuals' },
    { href: '/history/stories-documenting-history-of-the-lake', label: 'Stories: Documenting History of the Lake' },
    { href: '/history/newspaper-clippings-collection-of-lac-bernard', label: 'Newspaper Clippings Collection of Lac Bernard' },
    { href: '/history/historical-research-and-sources', label: 'Historical Research and Sources' },
    { href: '/history/properties-and-deeds', label: 'Properties and Deeds' },
    { href: '/history/related-history', label: 'Related History' },
  ],
  fr: [
    { href: '/history', label: 'Histoire' },
    { href: '/history/first-nations', label: 'Premières Nations' },
    { href: '/history/fishing-club', label: 'Club de pêche' },
    { href: '/history/maps', label: 'Cartes' },
    { href: '/history/aerial-photos', label: 'Photos aériennes' },
    { href: '/history/stories-documenting-families-and-individuals', label: 'Récits: Documentation des familles et individus' },
    { href: '/history/stories-documenting-history-of-the-lake', label: 'Récits: Documentation de l\'histoire du lac' },
    { href: '/history/newspaper-clippings-collection-of-lac-bernard', label: 'Collection de coupures de journaux du lac Bernard' },
    { href: '/history/historical-research-and-sources', label: 'Recherche historique et sources' },
    { href: '/history/properties-and-deeds', label: 'Propriétés et titres' },
    { href: '/history/related-history', label: 'Histoire connexe' },
  ],
};

const communityNav: { en: NavItem[]; fr: NavItem[] } = {
  en: [
    { href: '/community', label: 'Community' },
    { href: '/community/regatta', label: 'Annual Regatta' },
    {
      href: '/community/security',
      label: 'Security',
      children: [
        { href: '/community/security/police', label: 'Police' },
        { href: '/community/security/emergency-contacts', label: 'Emergency Contacts' },
        { href: '/community/security/fire', label: 'Fire' },
        { href: '/community/security/neighbourhood-watch', label: 'Neighbourhood Watch Program' },
      ],
    },
  ],
  fr: [
    { href: '/community', label: 'Communauté' },
    { href: '/community/regatta', label: 'Régate annuelle' },
    {
      href: '/community/security',
      label: 'Sécurité',
      children: [
        { href: '/community/security/police', label: 'Police' },
        { href: '/community/security/emergency-contacts', label: 'Contacts d\'urgence' },
        { href: '/community/security/fire', label: 'Incendie' },
        { href: '/community/security/neighbourhood-watch', label: 'Programme de surveillance de quartier' },
      ],
    },
  ],
};

// Select navigation based on section
const navItems = section === 'about' ? aboutNav[currentLang] : section === 'environment' ? environmentNav[currentLang] : section === 'history' ? historyNav[currentLang] : section === 'community' ? communityNav[currentLang] : null;
---

<html lang={currentLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | {site.siteNameSuffix}</title>
    <meta
      name="description"
      content={description || site.pageMetaDescriptionFallback(title)}
    />
    <Analytics />
    <SpeedInsights />
    <script async src="https://tally.so/widgets/embed.js"></script>
  </head>

  <body>
    <SiteHeader />

    <main id="main-content">
      <section class="section">
        <div class="container">
          {navItems ? (
            <div class="pageWithSidebar">
              <aside class="sidebar">
                <nav class="sidebarNav" aria-label="Section navigation">
                  {navItems?.map((item) => {
                    const normalizedHref = item.href.replace(/^\/(fr|en)(\/|$)/, '/');
                    const isActive = currentPath === item.href || currentPath === normalizedHref || currentPath === getLocalizedHref(normalizedHref, currentLang);
                    const hasChildren = item.children && item.children.length > 0;
                    // Always show children if they exist
                    const showChildren = hasChildren;
                    
                    return (
                      <div class="navItem">
                        <a 
                          href={getLocalizedHref(normalizedHref, currentLang)} 
                          class={isActive ? 'active' : ''}
                        >
                          {item.label}
                        </a>
                        {showChildren && item.children && (
                          <div class="navChildren">
                            {item.children.map((child) => {
                              const childNormalizedHref = child.href.replace(/^\/(fr|en)(\/|$)/, '/');
                              const isChildActive = currentPath === child.href || currentPath === childNormalizedHref || currentPath === getLocalizedHref(childNormalizedHref, currentLang);
                              return (
                                <a 
                                  href={getLocalizedHref(childNormalizedHref, currentLang)} 
                                  class={isChildActive ? 'active' : ''}
                                >
                                  {child.label}
                                </a>
                              );
                            })}
                          </div>
                        )}
                      </div>
                    );
                  })}
                </nav>
              </aside>
              <div class="pageContent prose">
                <h1>{title}</h1>
                {Content && <Content />}
                <slot name="extra" />
              </div>
            </div>
          ) : (
            <div class="prose">
              <h1>{title}</h1>
              {Content && <Content />}
              <slot name="extra" />
            </div>
          )}
        </div>
      </section>
    </main>

    <SiteFooter />
  </body>
</html>
