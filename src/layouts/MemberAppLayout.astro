---
import '../styles/theme.css';
import '../styles/components.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import type { MemberLocale } from '../lib/members/i18n';
import Analytics from '@vercel/analytics/astro';

interface Props {
  lang: MemberLocale;
  title: string;
  description: string;
  heroTitle: string;
  heroSubtitle?: string;
  /** Smaller workspace title — useful for dense admin screens */
  compactHero?: boolean;
  /** Match hero title column width to `.adminConsole` (1100px), not the default member reading column (40rem). */
  alignHeroWithAdmin?: boolean;
}

const { lang, title, description, heroTitle, heroSubtitle, compactHero = false, alignHeroWithAdmin = false } =
  Astro.props;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <Analytics />
  </head>

  <body>
    <SiteHeader />

    <main id="main-content" aria-labelledby="member-workspace-title">
      <header class={compactHero ? 'memberWorkspaceHead memberWorkspaceHead--compact' : 'memberWorkspaceHead'}>
        <div
          class:list={[
            'container',
            'memberWorkspaceHeadInner',
            { 'memberWorkspaceHeadInner--alignAdmin': alignHeroWithAdmin },
          ]}
        >
          <h1 class="memberWorkspaceTitle" id="member-workspace-title">{heroTitle}</h1>
          <slot name="hero-meta" />
          {heroSubtitle !== undefined && heroSubtitle !== '' && (
            <p class="memberWorkspaceLead">{heroSubtitle}</p>
          )}
        </div>
      </header>
      <div class="memberWorkspaceBody">
        <slot />
      </div>
    </main>

    <SiteFooter />
  </body>
</html>

<style>
  .memberWorkspaceHead {
    padding: 1.5rem 0 1.15rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
  }

  /* Align page title with the member content column (same max-width as `.memberHomeProse`) */
  .memberWorkspaceHeadInner {
    max-width: min(var(--member-column-max), 100%);
    margin-inline: auto;
  }

  /* Admin shell uses `.adminConsole { max-width: 1100px }` — keep the “Administration” title on the same edges */
  .memberWorkspaceHeadInner.memberWorkspaceHeadInner--alignAdmin {
    max-width: min(1100px, 100%);
  }

  .memberWorkspaceTitle {
    margin: 0;
    font-size: clamp(1.35rem, 2.2vw, 1.65rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--text);
  }

  .memberWorkspaceLead {
    margin: 0.4rem 0 0;
    font-size: 1rem;
    color: var(--muted);
    line-height: 1.45;
    max-width: 36rem;
  }

  .memberWorkspaceHead--compact {
    padding: 1rem 0 0.85rem;
  }

  .memberWorkspaceHead--compact .memberWorkspaceTitle {
    font-size: clamp(1.1rem, 1.85vw, 1.35rem);
  }

  .memberWorkspaceHead--compact .memberWorkspaceLead {
    font-size: 0.875rem;
  }

  /* Tighter top gap than default `.section` now that there is no hero band */
  .memberWorkspaceBody :global(.section:first-child) {
    padding-top: 1.75rem;
  }

  /* Let member content shrink so nested tables can’t force horizontal page overflow */
  .memberWorkspaceBody {
    min-width: 0;
  }
</style>
