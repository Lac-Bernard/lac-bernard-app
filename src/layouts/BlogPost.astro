---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import '../styles/theme.css';
import '../styles/components.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { siteUi } from '../i18n/site';
import { getLocalizedPath, languageFromAstro } from '../utils/i18n';
import { blogPostSlug, isBlogPostInLocale } from '../utils/blog';
import Analytics from '@vercel/analytics/astro';

type Props = CollectionEntry<'blog'>['data'] & {
	currentPostId?: string;
};

const { title, description, pubDate, updatedDate, heroImage, currentPostId } = Astro.props;

// Ensure pubDate is a valid Date object
if (!pubDate) {
	throw new Error(`Missing pubDate for blog post: ${title || 'unknown'}`);
}

// Ensure pubDate is a Date instance
const pubDateObj = pubDate instanceof Date ? pubDate : new Date(pubDate);
if (isNaN(pubDateObj.getTime())) {
	throw new Error(`Invalid pubDate for blog post ${title}: ${pubDate}`);
}

const updatedDateObj = updatedDate ? (updatedDate instanceof Date ? updatedDate : new Date(updatedDate)) : null;

// Get current post ID from props or URL
const postId = currentPostId || Astro.url.pathname.split('/').filter(Boolean).pop() || '';

const lang = languageFromAstro(Astro);
const site = siteUi[lang];
const isFrench = lang === 'fr';

// Get latest 10 blog posts for sidebar (filter by language)
const allPosts = await getCollection('blog');
const latestPosts = allPosts
	.filter((post) => isBlogPostInLocale(post.id, isFrench ? 'fr' : 'en'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 10);
---

<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title} – {site.siteNameSuffix}</title>
		<meta name="description" content={description} />
		<Analytics />
	</head>

	<body>
		<SiteHeader />

		<main id="main-content">
			<section class="section">
				<div class="container">
					<div class="pageWithSidebar">
						<aside class="sidebar">
							<nav class="sidebarNav" aria-label={lang === 'fr' ? 'Navigation du blog' : 'Blog navigation'}>
								<h2 class="sidebarTitle">{lang === 'fr' ? 'Publications récentes' : 'Recent Posts'}</h2>
								{latestPosts.map((post) => {
									const baseSlug = blogPostSlug(post.id);
									const isActive = baseSlug === postId || post.id === postId;
									const postPath = `${getLocalizedPath(`/news/${baseSlug}`, lang)}/`;
									return (
										<a 
											href={postPath}
											class={isActive ? 'active' : ''}
										>
											{post.data.title}
										</a>
									);
								})}
								<a href={`${getLocalizedPath('/news', lang)}/`} class="seeAllLink">{lang === 'fr' ? 'Voir toutes les publications →' : 'See all posts →'}</a>
							</nav>
						</aside>
						<div class="pageContent">
							<article>
								{heroImage && (
									<div class="hero-image">
										<Image width={1020} height={510} src={heroImage} alt="" />
									</div>
								)}
								<div class="prose">
									<div class="post-header">
										<div class="post-date">
											<FormattedDate date={pubDateObj} lang={lang} />
											{updatedDateObj && (
												<div class="last-updated-on">
													{lang === 'fr' ? 'Dernière mise à jour le' : 'Last updated on'} <FormattedDate date={updatedDateObj} lang={lang} />
												</div>
											)}
										</div>
										<h1>{title}</h1>
									</div>
									<slot />
								</div>
							</article>
						</div>
					</div>
				</div>
			</section>
		</main>

		<SiteFooter />

		<style>
			.hero-image {
				margin-bottom: var(--spacing-section);
				text-align: center;
			}
			
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--shadow);
				max-width: 100%;
				height: auto;
			}
			
			.post-header {
				margin-bottom: 32px;
				text-align: center;
			}
			
			.post-date {
				margin-bottom: 12px;
				color: var(--muted);
				font-size: 16px;
			}
			
			.last-updated-on {
				margin-top: 8px;
				font-style: italic;
				font-size: 14px;
			}
			
			.post-header h1 {
				margin: 0;
				font-size: clamp(32px, 4vw, 48px);
				line-height: 1.2;
				letter-spacing: -.02em;
			}
			
			.prose {
				max-width: 100%;
			}
			
			.prose :global(h2) {
				margin: 32px 0 16px;
				font-size: 28px;
				letter-spacing: -.02em;
			}
			
			.prose :global(h3) {
				margin: 24px 0 12px;
				font-size: 22px;
			}
			
			.prose :global(p) {
				margin: 0 0 18px;
				color: var(--text);
				font-size: 19px;
				line-height: 1.6;
			}
			
			.prose :global(ul),
			.prose :global(ol) {
				margin: 0 0 18px;
				padding-left: 24px;
			}
			
			.prose :global(li) {
				margin: 0 0 8px;
				color: var(--text);
				font-size: 19px;
				line-height: 1.6;
			}
			
			.prose :global(a) {
				color: #0066cc;
				text-decoration: underline;
				text-decoration-color: rgba(0,102,204,.3);
				text-underline-offset: 2px;
				transition: all 120ms ease;
			}
			
			.prose :global(a:hover) {
				color: #0052a3;
				text-decoration-color: rgba(0,102,204,.6);
			}
			
			.prose :global(strong) {
				font-weight: 600;
			}
			
			.prose :global(em) {
				font-style: italic;
			}
			
			.sidebarTitle {
				margin: 0 0 12px;
				font-size: 18px;
				font-weight: 600;
				color: var(--text);
				padding: 0 14px;
			}
			
			.seeAllLink {
				margin-top: 12px;
				padding-top: 12px;
				border-top: 1px solid var(--border);
				font-weight: 600;
				color: var(--color-primary);
			}
			
			.seeAllLink:hover {
				background: rgba(72,196,255,.1);
				color: var(--text);
			}
		</style>
	</body>
</html>
