---
import '../styles/theme.css';
import '../styles/components.css';
import SiteHeader from '@/components/SiteHeader.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import type { Language } from '@/utils/i18n';
import { loadContentPage } from '@/utils/loadContentPage';
import { memberPaths } from '@/lib/members/i18n';
import { membershipUi } from '@/i18n/membership';
import { siteUi } from '@/i18n/site';

interface Props {
	lang: Language;
}

const { lang } = Astro.props;
const ui = membershipUi[lang];
const site = siteUi[lang];

const page = await loadContentPage(lang, 'membership');
const title = (page.frontmatter?.title as string | undefined) ?? ui.defaultTitle;
const description = page.frontmatter?.description as string | undefined;
const { Content } = page;

const metaDescription = description ?? site.pageMetaDescriptionFallback(title);
const accountPath = memberPaths[lang].account;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | {site.siteNameSuffix}</title>
    <meta name="description" content={metaDescription} />
  </head>

  <body>
    <SiteHeader />

    <main id="main-content">
      <section class="hero" aria-label={ui.heroAriaLabel}>
        <div class="container heroInner">
          <div class="heroCopy">
            <h1>{title}</h1>
            <p class="heroIntro">{ui.heroAccountIntro}</p>
            <div class="heroActions">
              <a href={accountPath} class="btnPrimary heroAccountBtn">{ui.heroAccountCta}</a>
            </div>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="container">
          <div class="prose">
            {Content && <Content />}
          </div>
        </div>
      </section>
    </main>

    <SiteFooter />
  </body>
</html>

<style>
  /*
   * No photo hero: on-disk JPEGs are small/compressed and look poor full-bleed.
   * Lake-toned gradient ties to the site primary (cyan) without a weak stock image.
   */
  .hero {
    padding: 72px 0 var(--spacing-section);
    position: relative;
    color: white;
    background-color: #0e3040;
    background-image:
      radial-gradient(ellipse 100% 140% at 18% -20%, rgba(72, 196, 255, 0.34), transparent 55%),
      radial-gradient(ellipse 85% 90% at 92% 108%, rgba(72, 196, 255, 0.18), transparent 52%),
      linear-gradient(168deg, #0a2230 0%, #143e50 44%, #0c2834 100%);
  }

  .hero .container {
    position: relative;
  }

  .heroInner {
    display: block;
  }

  .heroCopy {
    color: white;
  }

  .hero h1 {
    margin: 0 0 18px;
    font-size: clamp(40px, 5vw, 64px);
    line-height: 1.06;
    letter-spacing: -.03em;
    color: white;
  }

  .heroIntro {
    margin: 0 0 22px;
    max-width: 36rem;
    font-size: clamp(17px, 2vw, 20px);
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.92);
  }

  .heroActions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .heroAccountBtn {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .membership-actions {
    display: flex;
    gap: 14px;
    margin: 24px 0;
    flex-wrap: wrap;
  }

  .membership-actions .btnPrimary {
    flex: 1;
    min-width: 200px;
    text-align: center;
  }
</style>
