---
import { languageFromAstro } from '../utils/i18n';

const currentLang = languageFromAstro(Astro);

const footerText = {
  en: `© ${new Date().getFullYear()} Owners' and Residents' Association of Lac Bernard.`,
  fr: `© ${new Date().getFullYear()} Association des propriétaires et résidents du Lac Bernard.`,
};
---

<footer class="footer">
  <div class="container footerInner">
    <div class="muted">{footerText[currentLang]}</div>
  </div>
</footer>
