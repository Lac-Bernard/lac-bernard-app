---
import {
	getAlternateLanguage,
	getEnglishPathFromPathname,
	getLocalizedHref,
	getLocalizedPath,
	languageFromAstro,
	type Language,
} from '../utils/i18n';

const currentPath = Astro.url.pathname;
const currentLang = languageFromAstro(Astro);
const alternateLang = getAlternateLanguage(currentLang);

// Get the path without locale prefix for switching
// Match /en or /fr only when followed by / or end of string, not part of a word
const pathWithoutLocale = currentPath.replace(/^\/(en|fr)(\/|$)/, '/') || '/';
const alternatePath = getLocalizedPath(pathWithoutLocale, alternateLang);

// Navigation labels
const navLabels = {
	en: {
		home: 'Home',
		about: 'About',
		membership: 'Membership',
		environment: 'Environment',
		community: 'Community',
		history: 'History',
		contact: 'Contact Us',
	},
	fr: {
		home: 'Accueil',
		about: 'À propos',
		membership: 'Adhésion',
		environment: 'Environnement',
		community: 'Communauté',
		history: 'Histoire',
		contact: 'Contactez-nous',
	},
};

const labels = navLabels[currentLang];
const altLabels = navLabels[alternateLang];

// Determine which section is currently active based on the path
function getActiveSection(path: string): string | null {
	const englishPath = getEnglishPathFromPathname(path).replace(/\/$/, '') || '/';

	if (englishPath.startsWith('/about')) {
		return 'about';
	}
	if (englishPath.startsWith('/membership')) {
		return 'membership';
	}
	if (englishPath.startsWith('/environment')) {
		return 'environment';
	}
	if (englishPath.startsWith('/community')) {
		return 'community';
	}
	if (englishPath.startsWith('/history')) {
		return 'history';
	}
	if (englishPath.startsWith('/contact')) {
		return 'contact';
	}

	return null;
}

const activeSection = getActiveSection(currentPath);
---


<a href="#main-content" class="skip-link">Skip to main content</a>
<header class="topbar">
  <div class="container topbarInner">
    <a class="brand" href={getLocalizedHref('/', currentLang)}>
      <img src="/images/lac_bernard_logo.svg" alt="Lac Bernard Association" class="brandLogo" />
    </a>
    <button class="navToggle" aria-label="Toggle navigation menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <nav class="nav" id="mainNav">
      <a href={getLocalizedHref('/about', currentLang)} class={activeSection === 'about' ? 'navCta' : ''}>{labels.about}</a>
      
      <a href={getLocalizedHref('/membership', currentLang)} class={activeSection === 'membership' ? 'navCta' : ''}>{labels.membership}</a>
      
      <a href={getLocalizedHref('/environment', currentLang)} class={activeSection === 'environment' ? 'navCta' : ''}>{labels.environment}</a>
      
      <a href={getLocalizedHref('/community', currentLang)} class={activeSection === 'community' ? 'navCta' : ''}>{labels.community}</a>

      <a href={getLocalizedHref('/history', currentLang)} class={activeSection === 'history' ? 'navCta' : ''}>{labels.history}</a>
      
      <a href={getLocalizedHref('/contact', currentLang)} class={activeSection === 'contact' ? 'navCta' : ''}>{labels.contact}</a>
      
      <a href={alternatePath} class="langToggle" aria-label={`Switch to ${altLabels.home}`}>
        {alternateLang.toUpperCase()}
      </a>
    </nav>
  </div>
</header>

<script>
  const navToggle = document.querySelector('.navToggle');
  const nav = document.getElementById('mainNav');
  
  if (navToggle && nav) {
    navToggle.addEventListener('click', () => {
      const isExpanded = navToggle.getAttribute('aria-expanded') === 'true';
      navToggle.setAttribute('aria-expanded', String(!isExpanded));
      nav.classList.toggle('isOpen');
    });
    
    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      const target = e.target as Node | null;
      if (target && !nav.contains(target) && !navToggle.contains(target)) {
        navToggle.setAttribute('aria-expanded', 'false');
        nav.classList.remove('isOpen');
      }
    });
  }
</script>

<style>
  .langToggle {
    margin-left: 8px;
    padding: 6px 12px !important;
    border: 1px solid var(--border) !important;
    background: rgba(0,0,0,.04) !important;
    font-weight: 600 !important;
    font-size: 15px !important;
    min-width: 44px;
    text-align: center;
  }
  
  .langToggle:hover {
    background: rgba(72,196,255,.1) !important;
    border-color: rgba(72,196,255,.3) !important;
  }
  
  @media (max-width: 920px) {
    .langToggle {
      margin-left: 0;
    }
  }
</style>
