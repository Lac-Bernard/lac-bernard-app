---
import MemberAppLayout from '../../layouts/MemberAppLayout.astro';
import MemberSessionHeroMeta from './MemberSessionHeroMeta.astro';
import { memberCopy, memberPaths, type MemberLocale } from '../../lib/members/i18n';
import type { MemberProfile } from '../../lib/members/memberLookup';

interface Props {
	locale: MemberLocale;
	mode: 'join' | 'edit';
	email: string;
	member: MemberProfile | null;
	nextUrl: string;
}

const { locale, mode, email, member, nextUrl } = Astro.props;
const t = memberCopy[locale];
const paths = memberPaths[locale];

const isEdit = mode === 'edit';
const title = isEdit ? t.profileEditTitle : t.profileJoinTitle;
const description = isEdit ? t.profileEditDescription : t.profileJoinDescription;
const heroTitle = isEdit ? t.profileEditHero : t.profileJoinHero;

const v = (s: string | null | undefined) => (s ?? '').trim();

const firstName = isEdit ? v(member?.first_name) : '';
const lastName = isEdit ? v(member?.last_name) : '';
const secondaryFirstName = isEdit ? v(member?.secondary_first_name) : '';
const secondaryLastName = isEdit ? v(member?.secondary_last_name) : '';
const secondaryEmail = isEdit ? v(member?.secondary_email) : '';
const primaryPhone = isEdit ? v(member?.primary_phone) : '';
const secondaryPhone = isEdit ? v(member?.secondary_phone) : '';
const lakeCivic = isEdit ? v(member?.lake_civic_number) : '';
const lakeStreet = isEdit ? v(member?.lake_street_name) : '';
const addr = isEdit ? v(member?.primary_address) : '';
const city = isEdit ? v(member?.primary_city) : '';
const province = isEdit ? v(member?.primary_province) : '';
const country = isEdit ? v(member?.primary_country) : '';
const postal = isEdit ? v(member?.primary_postal_code) : '';
const emailOptIn = isEdit ? Boolean(member?.email_opt_in) : false;
const hasSecondaryContact = Boolean(secondaryFirstName || secondaryLastName || secondaryEmail || secondaryPhone);
---

<MemberAppLayout lang={locale} title={title} description={description} heroTitle={heroTitle}>
	<MemberSessionHeroMeta slot="hero-meta" locale={locale} email={email} signInRedirect={paths.signIn} />
	<section class="section">
		<div class="container narrow">
			{!isEdit && <p class="intro">{t.profileJoinIntro}</p>}

			<form id="member-profile-form" class="profileForm" novalidate>
				<input type="hidden" name="nextUrl" value={nextUrl} />

				<fieldset class="profileFieldset">
					<legend class="profileLegend">{t.profileSectionContact}</legend>
					<div class="profileNamesGroup">
						<label class="fieldLabel" for="profile-email-readonly">{t.profileSignInEmail}</label>
						<input
							class="fieldInput fieldInputReadonly"
							id="profile-email-readonly"
							type="email"
							value={email}
							readonly
							tabindex={-1}
							aria-readonly="true"
						/>

						<label class="fieldLabel" for="first_name">{t.profileFirstName}</label>
						<input class="fieldInput" id="first_name" name="first_name" type="text" autocomplete="given-name" value={firstName} />

						<label class="fieldLabel" for="last_name">{t.profileLastName}</label>
						<input
							class="fieldInput"
							id="last_name"
							name="last_name"
							type="text"
							autocomplete="family-name"
							required
							value={lastName}
						/>

						<label class="fieldLabel" for="primary_phone">{t.profilePrimaryPhone}</label>
						<input class="fieldInput" id="primary_phone" name="primary_phone" type="text" autocomplete="tel" value={primaryPhone} />
					</div>

					<div
						id="secondary-contact-group"
						class:list={['profileNamesGroup', { 'profileNamesGroup--collapsed': !hasSecondaryContact }]}
					>
						<label class="toggleLabel" for="show_secondary_contact">
							<input
								class="toggleInput"
								id="show_secondary_contact"
								name="show_secondary_contact"
								type="checkbox"
								checked={hasSecondaryContact ? true : undefined}
							/>
							<span>{t.profileShowSecondaryMember}</span>
						</label>
						<p class="fieldHelp">{t.profileSecondaryMemberHelp}</p>
						<div
							id="secondary-contact-fields"
							hidden={!hasSecondaryContact}
							aria-hidden={!hasSecondaryContact ? 'true' : 'false'}
							class:list={['secondaryFields', { 'secondaryFields--hidden': !hasSecondaryContact }]}
						>
							<label class="fieldLabel" for="secondary_first_name">{t.profileSecondaryFirstName}</label>
							<input
								class="fieldInput"
								id="secondary_first_name"
								name="secondary_first_name"
								type="text"
								autocomplete="off"
								value={secondaryFirstName}
							/>

							<label class="fieldLabel" for="secondary_last_name">{t.profileSecondaryLastName}</label>
							<input
								class="fieldInput"
								id="secondary_last_name"
								name="secondary_last_name"
								type="text"
								autocomplete="off"
								value={secondaryLastName}
							/>

							<label class="fieldLabel" for="secondary_email">{t.profileSecondaryEmail}</label>
							<input
								class="fieldInput"
								id="secondary_email"
								name="secondary_email"
								type="email"
								autocomplete="email"
								value={secondaryEmail}
							/>

							<label class="fieldLabel" for="secondary_phone">{t.profileSecondaryPhone}</label>
							<input class="fieldInput" id="secondary_phone" name="secondary_phone" type="text" autocomplete="tel" value={secondaryPhone} />
						</div>
					</div>
				</fieldset>

				<fieldset class="profileFieldset">
					<legend class="profileLegend">{t.profileSectionLake}</legend>
					<p class="fieldHelp">{t.profileLakeHelp}</p>
					<label class="fieldLabel" for="lake_civic_number">{t.profileLakeCivic}</label>
					<input class="fieldInput" id="lake_civic_number" name="lake_civic_number" type="text" value={lakeCivic} />

					<label class="fieldLabel" for="lake_street_name">{t.profileLakeStreet}</label>
					<input class="fieldInput" id="lake_street_name" name="lake_street_name" type="text" value={lakeStreet} />
				</fieldset>

				<label class="checkLabel">
					<input type="checkbox" name="email_opt_in" checked={emailOptIn ? true : undefined} class="checkInput" />
					<span>{t.profileEmailOptIn}</span>
				</label>

				<p id="profile-form-message" class="formMessage" role="status" aria-live="polite"></p>

				<div class="profileActions">
					<button type="submit" class="btnPrimary" id="profile-submit">
						{isEdit ? t.profileSaveSubmit : t.profileCreateSubmit}
					</button>
					{isEdit && (
						<a class="btnGhost profileBack" href={paths.account}>{t.profileBackToAccount}</a>
					)}
				</div>
			</form>
		</div>
	</section>
</MemberAppLayout>

<script
	define:vars={{
		mode,
		nextUrl,
		initialHasSecondaryContact: hasSecondaryContact,
		preservedPrimaryAddress: addr,
		preservedPrimaryCity: city,
		preservedPrimaryProvince: province,
		preservedPrimaryCountry: country,
		preservedPrimaryPostalCode: postal,
		errNetwork: t.errorNetwork,
		errLastName: t.profileErrorLastName,
		errSecondaryEmail: t.profileErrorSecondaryEmail,
		errSecondaryContact: t.profileErrorSecondaryContact,
		errPhone: t.profileErrorPhone,
		errLakeAddress: t.profileErrorLakeAddress,
		errPrimaryEmail: t.profileErrorPrimaryEmail,
		errAlreadyMember: t.profileErrorAlreadyMember,
		errSave: t.profileErrorSave,
		accountPath: paths.account,
	}}
>
	const form = document.getElementById('member-profile-form');
	const msg = document.getElementById('profile-form-message');
	const submitBtn = document.getElementById('profile-submit');
	const showSecondaryContact = document.getElementById('show_secondary_contact');
	const secondaryGroup = document.getElementById('secondary-contact-group');
	const secondaryFields = document.getElementById('secondary-contact-fields');

	if (showSecondaryContact) {
		showSecondaryContact.checked = Boolean(initialHasSecondaryContact);
	}

	function syncSecondaryFields() {
		if (!showSecondaryContact || !secondaryFields) return;
		const enabled = showSecondaryContact.checked;
		secondaryGroup?.classList.toggle('profileNamesGroup--collapsed', !enabled);
		secondaryFields.classList.toggle('secondaryFields--hidden', !enabled);
		secondaryFields.hidden = !enabled;
		secondaryFields.setAttribute('aria-hidden', enabled ? 'false' : 'true');
		secondaryFields.querySelectorAll('input').forEach((input) => {
			input.disabled = !enabled;
		});
		if (!enabled) {
			secondaryFields.querySelectorAll('input').forEach((input) => {
				input.value = '';
			});
		}
	}

	showSecondaryContact?.addEventListener('change', syncSecondaryFields);
	syncSecondaryFields();

	function trimOrNull(value) {
		if (typeof value !== 'string') return null;
		const trimmed = value.trim();
		return trimmed === '' ? null : trimmed;
	}

	function isValidEmail(value) {
		return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);
	}

	function isPlausiblePhone(value) {
		const digits = value.replace(/[^\d]/g, '');
		return digits.length >= 10 && digits.length <= 15;
	}

	function validateBody(body) {
		if (!body.last_name) return errLastName;
		if (body.secondary_email && !isValidEmail(body.secondary_email)) return errSecondaryEmail;

		const phoneFields = [body.primary_phone, body.secondary_phone];
		if (phoneFields.some((value) => value && !isPlausiblePhone(value))) return errPhone;

		const hasLakeCivic = Boolean(trimOrNull(body.lake_civic_number));
		const hasLakeStreet = Boolean(trimOrNull(body.lake_street_name));
		if (hasLakeCivic !== hasLakeStreet) return errLakeAddress;

		if (showSecondaryContact?.checked) {
			const hasSecondaryValue = [
				body.secondary_first_name,
				body.secondary_last_name,
				body.secondary_email,
				body.secondary_phone,
			].some((value) => Boolean(trimOrNull(value)));
			if (!hasSecondaryValue) return errSecondaryContact;
		}

		return '';
	}

	function messageForApiError(error) {
		switch (error) {
			case 'last_name_required':
				return errLastName;
			case 'invalid_secondary_email':
				return errSecondaryEmail;
			case 'invalid_primary_email':
				return errPrimaryEmail;
			case 'invalid_primary_phone':
			case 'invalid_secondary_phone':
				return errPhone;
			case 'invalid_lake_address':
				return errLakeAddress;
			default:
				return errSave;
		}
	}

	function payloadFromForm(fd) {
		return {
			first_name: fd.get('first_name') || null,
			secondary_first_name: fd.get('secondary_first_name') || null,
			last_name: String(fd.get('last_name') ?? '').trim(),
			secondary_last_name: fd.get('secondary_last_name') || null,
			secondary_email: fd.get('secondary_email') || null,
			primary_phone: fd.get('primary_phone') || null,
			secondary_phone: fd.get('secondary_phone') || null,
			lake_civic_number: fd.get('lake_civic_number') || null,
			lake_street_name: fd.get('lake_street_name') || null,
			primary_address: preservedPrimaryAddress || null,
			primary_city: preservedPrimaryCity || null,
			primary_province: preservedPrimaryProvince || null,
			primary_country: preservedPrimaryCountry || null,
			primary_postal_code: preservedPrimaryPostalCode || null,
			email_opt_in: fd.get('email_opt_in') === 'on',
		};
	}

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();
		if (!msg || !submitBtn) return;
		msg.textContent = '';
		submitBtn.setAttribute('disabled', 'true');
		const fd = new FormData(form);
		const body = payloadFromForm(fd);
		const validationError = validateBody(body);
		if (validationError) {
			msg.textContent = validationError;
			submitBtn.removeAttribute('disabled');
			return;
		}
		try {
			const res = await fetch('/api/membership/profile', {
				method: mode === 'edit' ? 'PATCH' : 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify(body),
			});
			const data = await res.json().catch(() => ({}));
			if (res.status === 409 && data.error === 'already_member') {
				msg.textContent = errAlreadyMember;
				window.setTimeout(() => {
					window.location.href = nextUrl || accountPath;
				}, 1200);
				return;
			}
			if (!res.ok) {
				msg.textContent = messageForApiError(data.error);
				return;
			}
			window.location.href = nextUrl || accountPath;
		} catch {
			msg.textContent = errNetwork;
		} finally {
			submitBtn.removeAttribute('disabled');
		}
	});
</script>

<style>
	.narrow {
		max-width: min(var(--member-column-max), 100%);
	}

	.intro {
		margin: 0 0 1.35rem;
		padding: 1.05rem 1.15rem;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 18px;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.99), rgba(248, 250, 252, 0.92));
		line-height: 1.6;
		color: var(--text, #334155);
		box-shadow:
			0 1px 2px rgba(15, 23, 42, 0.04),
			0 12px 32px rgba(15, 23, 42, 0.05);
		font-size: 0.96rem;
	}

	.profileForm {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.profileFieldset {
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 18px;
		padding: 1.35rem 1.35rem 1.4rem;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.99), rgba(248, 250, 252, 0.92));
		box-shadow:
			0 1px 2px rgba(15, 23, 42, 0.04),
			0 12px 32px rgba(15, 23, 42, 0.05);
	}

	.profileNamesGroup {
		border: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.7rem;
	}

	.profileNamesGroup .profileLegend {
		padding: 0;
	}

	.profileLegend {
		font-weight: 700;
		font-size: 1rem;
		letter-spacing: -0.01em;
		padding: 0;
		color: var(--text, #0f172a);
	}

	.fieldLabel {
		font-weight: 600;
		font-size: 0.82rem;
		letter-spacing: 0.01em;
		color: var(--text, #1e293b);
	}

	.fieldInput {
		width: 100%;
		padding: 0.78rem 0.9rem;
		border-radius: 10px;
		border: 1px solid rgba(148, 163, 184, 0.35);
		background: rgba(255, 255, 255, 0.96);
		font-size: 0.98rem;
		line-height: 1.4;
		color: var(--text, #0f172a);
		box-sizing: border-box;
		box-shadow: inset 0 1px 2px rgba(15, 23, 42, 0.03);
		transition:
			border-color 160ms ease,
			box-shadow 160ms ease,
			background-color 160ms ease;
	}

	.fieldInputReadonly {
		background: linear-gradient(180deg, rgba(248, 250, 252, 0.96), rgba(241, 245, 249, 0.96));
		color: var(--color-muted, #475569);
		border-color: rgba(148, 163, 184, 0.25);
	}

	.fieldInput:focus {
		outline: none;
		border-color: rgba(37, 99, 235, 0.52);
		box-shadow:
			0 0 0 4px rgba(37, 99, 235, 0.12),
			inset 0 1px 2px rgba(15, 23, 42, 0.03);
	}

	.fieldHelp {
		margin: 0 0 0.15rem;
		font-size: 0.92rem;
		line-height: 1.55;
		color: var(--color-muted, #475569);
		max-width: 34rem;
	}

	.toggleLabel {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		font-size: 0.94rem;
		font-weight: 600;
		color: var(--text, #1e293b);
		cursor: pointer;
	}

	.toggleInput {
		margin: 0;
		flex-shrink: 0;
	}

	.secondaryFields {
		display: flex;
		flex-direction: column;
		gap: 0.7rem;
	}

	.secondaryFields--hidden {
		display: none;
	}

	.secondaryFields[hidden] {
		display: none;
	}

	.checkLabel {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
		padding: 0.9rem 1rem;
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 14px;
		background: rgba(248, 250, 252, 0.72);
		font-size: 0.94rem;
		line-height: 1.5;
		cursor: pointer;
	}

	.checkInput {
		margin-top: 0.2rem;
		flex-shrink: 0;
	}

	.formMessage {
		min-height: 1.25em;
		font-size: 0.94rem;
		line-height: 1.45;
		color: #b00020;
	}

	.profileActions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.85rem;
		margin-top: 0.1rem;
		padding-top: 0.25rem;
	}

	.profileBack {
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 48px;
		padding: 0 1.15rem;
	}

	.profileActions :global(.btnPrimary),
	.profileActions :global(.btnGhost) {
		min-height: 48px;
		padding-inline: 1.15rem;
		font-size: 0.95rem;
		border-radius: 10px;
	}

	.profileActions :global(.btnPrimary) {
		box-shadow: 0 10px 24px rgba(37, 99, 235, 0.18);
	}

	.profileActions :global(.btnGhost) {
		background: rgba(255, 255, 255, 0.92);
	}

	@media (max-width: 640px) {
		.narrow {
			max-width: 100%;
		}

		.profileFieldset {
			padding: 1.1rem 1rem 1.15rem;
			border-radius: 16px;
		}

		.profileActions {
			flex-direction: column;
			align-items: stretch;
		}

		.profileActions :global(.btnPrimary),
		.profileActions :global(.btnGhost),
		.profileBack {
			width: 100%;
		}
	}
</style>
