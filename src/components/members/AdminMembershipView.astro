---
import MemberAppLayout from '../../layouts/MemberAppLayout.astro';
import { memberCopy, memberPaths, type MemberLocale } from '../../lib/members/i18n';
import { getMembershipCalendarYear } from '../../lib/members/membershipYear';

interface Props {
	locale: MemberLocale;
	email: string;
}

const { locale, email } = Astro.props;
const t = memberCopy[locale];
const paths = memberPaths[locale];
const heroSubtitle = email;
const defaultMembershipYear = getMembershipCalendarYear();

const y = String(defaultMembershipYear);
const scopeActiveLabel = t.adminScopeActive.replace(/\{\{year\}\}/g, y);
const scopeNotRenewedLabel = t.adminScopeNotRenewed.replace(/\{\{year\}\}/g, y);
const numberLocale = locale === 'fr' ? 'fr-CA' : 'en-CA';

const adminKeys = [
	'adminNavPending',
	'adminNavOverview',
	'adminNavMembers',
	'adminTableName',
	'adminTableEmail',
	'adminTableYear',
	'adminTableTier',
	'adminTableStatus',
	'adminTableExpectedFee',
	'adminTableCreated',
	'adminTableActions',
	'adminSearchLabel',
	'adminSortLabel',
	'adminSortCreatedDesc',
	'adminSortNameAsc',
	'adminPendingEmpty',
	'adminCancelPendingAriaLabel',
	'adminCancelPendingConfirm',
	'adminCancelPendingSuccess',
	'adminCancelPendingErrorNotPending',
	'adminRecordPaymentBtn',
	'adminPaymentHeading',
	'adminAmountLabel',
	'adminMethodLabel',
	'adminMethodEtransfer',
	'adminMethodCheque',
	'adminMethodCash',
	'adminMethodUnknown',
	'adminMethodStripe',
	'adminDateLabel',
	'adminNotesLabel',
	'adminSubmitPaymentBtn',
	'adminMemberOpen',
	'adminLoading',
	'adminErrorGeneric',
	'adminPageOf',
	'adminPrevPage',
	'adminNextPage',
	'adminFilterApply',
	'adminMembershipYearLabel',
	'adminFilterTierLabel',
	'adminFilterTierAll',
	'adminFilterTierGeneral',
	'adminFilterTierAssociate',
	'adminScopeLabel',
	'adminScopeEveryone',
	'adminScopeHasHistory',
	'adminScopeActive',
	'adminScopeNotRenewed',
	'adminExportEmails',
	'adminExportEmailsCopied',
	'adminCopyEmailsFallbackPrompt',
	'adminCopyEmailsDialogCopy',
	'adminCopyEmailsDialogClose',
	'adminExportEmailsHint',
	'adminExportEmailsEmpty',
	'adminOverviewPaymentsTitle',
	'adminOverviewMembersTitle',
	'adminOverviewMembershipsTitle',
	'adminOverviewAuditTitle',
	'adminOverviewCountPending',
	'adminOverviewCountActive',
	'adminOverviewCountTotal',
	'adminTableAmount',
	'adminTablePaymentDate',
	'adminAuditWhen',
	'adminAuditAction',
	'adminAuditEntityType',
	'adminAuditEntityId',
	'adminPendingBadge',
	'adminAddMemberNav',
] as const;

const adminStrings = Object.fromEntries(adminKeys.map((k) => [k, t[k as keyof typeof t]])) as Record<string, string>;

const tierLabels = { general: t.tierGeneral, associate: t.tierAssociate };
---

<MemberAppLayout
  lang={locale}
  title={t.adminTitle}
  description={t.adminDescription}
  heroTitle={t.adminHero}
  heroSubtitle={heroSubtitle}
  alignHeroWithAdmin
>
  <section class="section alt adminPage">
    <div class="container adminConsole">
      <div class="adminShell">
        <div class="adminShellHeader">
          <p class="adminLead">{t.adminBody}</p>
          <p class="adminHeaderAddMember">
            <a href={paths.adminMemberNew} class="adminBtn adminBtn--outline">{t.adminAddMemberNav}</a>
          </p>
        </div>

        <div class="adminTabBar">
          <div class="adminTabs" role="tablist" aria-label="Admin">
            <button type="button" class="adminTab" role="tab" data-admin-tab="overview" aria-selected="true">{t.adminNavOverview}</button>
            <button type="button" class="adminTab" role="tab" data-admin-tab="pending" aria-selected="false">
              {t.adminNavPending}
              <span id="admin-pending-badge" class="adminTabBadge" hidden></span>
            </button>
            <button type="button" class="adminTab" role="tab" data-admin-tab="members" aria-selected="false">{t.adminNavMembers}</button>
          </div>
        </div>

        <p id="admin-status" class="adminStatus" aria-live="polite"></p>

        <div data-admin-panel="overview" class="adminPanel adminCard">
          <div id="admin-overview-mount" class="adminOverviewMount"></div>
        </div>

        <div data-admin-panel="pending" class="adminPanel adminCard" hidden>
          <div class="adminToolbar adminToolbar--lead">
            <button type="button" class="adminBtn adminBtn--outline" id="admin-export-emails-pending">{t.adminExportEmails}</button>
            <p class="adminHint adminHint--toolbar">{t.adminExportEmailsHint}</p>
          </div>
          <div class="tableWrap">
            <table class="adminTable">
              <thead>
                <tr>
                  <th>{t.adminTableName}</th>
                  <th>{t.adminTableEmail}</th>
                  <th>{t.adminTableYear}</th>
                  <th>{t.adminTableTier}</th>
                  <th>{t.adminTableStatus}</th>
                  <th>{t.adminTableExpectedFee}</th>
                  <th>{t.adminTableActions}</th>
                </tr>
              </thead>
              <tbody id="admin-pending-body"></tbody>
            </table>
          </div>
        </div>

        <div data-admin-panel="members" class="adminPanel adminCard" hidden>
          <form id="admin-members-search" class="adminToolbar">
            <label>
              {t.adminSearchLabel}
              <input type="search" id="admin-members-q" name="q" class="adminInput" />
            </label>
            <label>
              {t.adminSortLabel}
              <select id="admin-members-sort" class="adminInput">
                <option value="created_at_desc">{t.adminSortCreatedDesc}</option>
                <option value="last_name_asc">{t.adminSortNameAsc}</option>
              </select>
            </label>
            <label>
              {t.adminScopeLabel}
              <select id="admin-members-scope" name="membership" class="adminInput">
                <option value="all">{t.adminScopeEveryone}</option>
                <option value="has_membership_history">{t.adminScopeHasHistory}</option>
                <option value="active" selected>{scopeActiveLabel}</option>
                <option value="not_active">{scopeNotRenewedLabel}</option>
              </select>
            </label>
            <label>
              {t.adminMembershipYearLabel}
              <input
                type="number"
                id="admin-members-year"
                name="year"
                class="adminInput adminInput--year"
                min="2000"
                max="2100"
                step="1"
                value={defaultMembershipYear}
              />
            </label>
            <label>
              {t.adminFilterTierLabel}
              <select id="admin-members-tier" name="tier" class="adminInput">
                <option value="all">{t.adminFilterTierAll}</option>
                <option value="general">{t.adminFilterTierGeneral}</option>
                <option value="associate">{t.adminFilterTierAssociate}</option>
              </select>
            </label>
            <button type="submit" class="adminBtn adminBtn--outline">{t.adminFilterApply}</button>
            <button type="button" class="adminBtn adminBtn--outline" id="admin-export-emails-members">{t.adminExportEmails}</button>
          </form>
          <p class="adminHint">{t.adminExportEmailsHint}</p>
          <div class="tableWrap">
            <table class="adminTable adminTable--members">
              <thead>
                <tr>
                  <th>{t.adminTableName}</th>
                  <th>{t.adminTableEmail}</th>
                  <th>{t.adminTableTier}</th>
                  <th>{t.adminTableCreated}</th>
                </tr>
              </thead>
              <tbody id="admin-members-body"></tbody>
            </table>
          </div>
          <div class="adminPager">
            <button type="button" class="adminBtn adminBtn--ghost" id="admin-members-prev">{t.adminPrevPage}</button>
            <span id="admin-members-pageinfo"></span>
            <button type="button" class="adminBtn adminBtn--ghost" id="admin-members-next">{t.adminNextPage}</button>
          </div>
        </div>

        <div class="adminShellFooter">
          <form method="POST" action="/api/auth/sign-out" class="adminSignOutForm">
            <input type="hidden" name="redirect_to" value={paths.signIn} />
            <button type="submit" class="adminBtn adminBtn--link">{t.signOut}</button>
          </form>
        </div>
      </div>
    </div>

    <dialog id="admin-payment-dialog" class="adminDialog">
      <form id="admin-payment-form" class="adminPaymentForm">
        <h3>{t.adminPaymentHeading}</h3>
        <input type="hidden" id="admin-payment-membership-id" value="" />
        <label>
          {t.adminAmountLabel}
          <input type="number" name="amount" min="0" step="0.01" required class="adminInput" />
        </label>
        <label>
          {t.adminMethodLabel}
          <select name="method" required class="adminInput">
            <option value="e-transfer">{t.adminMethodEtransfer}</option>
            <option value="cheque">{t.adminMethodCheque}</option>
            <option value="cash">{t.adminMethodCash}</option>
            <option value="unknown">{t.adminMethodUnknown}</option>
          </select>
        </label>
        <label>
          {t.adminDateLabel}
          <input type="date" name="date" class="adminInput" />
        </label>
        <label>
          {t.adminNotesLabel}
          <input type="text" name="notes" class="adminInput" />
        </label>
        <div class="adminDialogActions">
          <button type="submit" class="adminBtn adminBtn--solid" value="default">{t.adminSubmitPaymentBtn}</button>
          <button type="button" class="adminBtn adminBtn--ghost" id="admin-payment-cancel">{t.checkoutModalCancel}</button>
        </div>
      </form>
    </dialog>
  </section>
</MemberAppLayout>

<script type="application/json" id="admin-console-data" set:html={JSON.stringify({ adminStrings, tierLabels, defaultMembershipYear, adminMembersBase: paths.adminMembers, numberLocale })}></script>
<script>
  import { initAdminConsole } from '../../scripts/admin-console';
  const el = document.getElementById('admin-console-data');
  const raw = el?.textContent;
  if (raw) {
    const { adminStrings, tierLabels, defaultMembershipYear, adminMembersBase, numberLocale } = JSON.parse(raw) as {
      adminStrings: Record<string, string>;
      tierLabels: { general: string; associate: string };
      defaultMembershipYear: number;
      adminMembersBase: string;
      numberLocale: string;
    };
    initAdminConsole(adminStrings, tierLabels, defaultMembershipYear, adminMembersBase, numberLocale);
  }
</script>

<style>
  .adminPage {
    --admin-radius: 12px;
    --admin-radius-sm: 8px;
    --admin-border: var(--border);
    --admin-surface: #fff;
    --admin-surface-muted: var(--panel);
    --admin-accent: rgba(28, 95, 118, 0.98);
    --admin-accent-hover: rgba(22, 78, 98, 1);
    --admin-accent-soft: rgba(72, 196, 255, 0.16);
    --admin-text: var(--text);
    --admin-font: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    font-family: var(--admin-font);
    font-size: 15px;
    line-height: 1.45;
    padding: 36px 0 48px;
  }

  .adminConsole {
    max-width: 1100px;
  }

  .adminShellHeader {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem 1rem;
    padding: 1rem 1.35rem 1rem;
    border-bottom: 1px solid var(--admin-border);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.7) 0%, var(--admin-surface) 100%);
  }

  .adminHeaderAddMember {
    margin: 0;
    flex-shrink: 0;
  }

  .adminLead {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--muted);
    max-width: 62ch;
  }

  .adminShell {
    background: var(--admin-surface);
    border: 1px solid var(--admin-border);
    border-radius: var(--admin-radius);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .adminTabBar {
    background: var(--admin-surface-muted);
    border-bottom: 1px solid var(--admin-border);
    padding: 0 0.25rem;
  }

  .adminTabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
  }

  .adminTab {
    position: relative;
    margin: 0;
    padding: 0.75rem 1.1rem;
    border: none;
    border-bottom: 2px solid transparent;
    background: transparent;
    color: var(--muted);
    font: inherit;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    border-radius: var(--admin-radius-sm) var(--admin-radius-sm) 0 0;
    transition:
      color 0.15s ease,
      background 0.15s ease;
  }

  .adminTab:hover {
    color: var(--admin-text);
    background: rgba(255, 255, 255, 0.5);
  }

  .adminTab[aria-selected='true'] {
    color: var(--admin-accent);
    background: var(--admin-surface);
    border-bottom-color: var(--admin-accent);
    font-weight: 600;
  }

  .adminTabBadge {
    display: inline-block;
    margin-left: 0.35rem;
    padding: 0.1rem 0.45rem;
    font-size: 0.72rem;
    font-weight: 700;
    vertical-align: middle;
    border-radius: 999px;
    background: rgba(176, 120, 0, 0.2);
    color: rgba(90, 60, 0, 0.95);
  }

  .adminStatus {
    margin: 0;
    padding: 0.65rem 1.25rem;
    font-size: 0.9rem;
    line-height: 1.4;
    border-bottom: 1px solid var(--admin-border);
    background: rgba(72, 196, 255, 0.08);
    color: var(--admin-text);
  }

  .adminStatus[data-error='1'] {
    background: rgba(176, 0, 32, 0.08);
    color: #8a1024;
  }

  .adminStatus[data-success='1'] {
    background: rgba(34, 120, 80, 0.1);
    color: rgba(18, 75, 50, 0.95);
  }

  .adminStatus:empty {
    display: none;
    padding: 0;
    border: none;
  }

  .adminPanel {
    padding: 1.35rem 1.4rem 1.6rem;
  }

  .adminPanel + .adminPanel {
    border-top: 1px solid var(--admin-border);
  }

  .adminToolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
    align-items: flex-end;
    margin-bottom: 1rem;
    padding: 0.85rem 1rem;
    background: var(--admin-surface-muted);
    border: 1px solid var(--admin-border);
    border-radius: var(--admin-radius-sm);
  }

  .adminToolbar--lead {
    align-items: center;
    gap: 1rem 1.25rem;
  }

  .adminHint--toolbar {
    margin: 0;
    flex: 1 1 12rem;
    min-width: 0;
  }

  .adminToolbar label {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
  }

  .adminHint {
    font-size: 0.88rem;
    color: var(--muted);
    margin: 0 0 0.85rem;
    line-height: 1.45;
  }

  .adminInput--year {
    max-width: 7rem;
  }

  .adminInput,
  .adminToolbar .adminInput {
    display: block;
    width: 100%;
    min-width: 0;
    max-width: 320px;
    margin: 0;
    padding: 0.5rem 0.65rem;
    font: inherit;
    font-size: 0.95rem;
    font-weight: 400;
    text-transform: none;
    letter-spacing: normal;
    color: var(--admin-text);
    background: #fff;
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }

  .adminInput:hover {
    border-color: rgba(0, 0, 0, 0.22);
  }

  .adminInput:focus {
    outline: none;
    border-color: rgba(72, 196, 255, 0.85);
    box-shadow: 0 0 0 3px var(--admin-accent-soft);
  }

  /**
   * All admin data tables (overview injects HTML too — scoped `.adminTable` would miss it).
   * One set of rules under `.adminPage` so pending, members, and overview match.
   */
  .adminPage :global(.tableWrap) {
    overflow-x: auto;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    margin: 0;
    box-sizing: border-box;
    border-radius: var(--admin-radius-sm);
    border: 1px solid var(--admin-border);
    background: var(--admin-surface);
  }

  .adminPage :global(.adminTable) {
    width: 100%;
    min-width: 420px;
    border-collapse: collapse;
    font-size: 0.8125rem;
    line-height: 1.4;
  }

  .adminPage :global(.adminTable th),
  .adminPage :global(.adminTable td) {
    padding: 0.55rem 0.75rem;
    text-align: left;
    vertical-align: middle;
    border-bottom: 1px solid var(--admin-border);
  }

  .adminPage :global(.adminTable th) {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--muted);
    background: var(--admin-surface-muted);
    white-space: nowrap;
  }

  .adminPage :global(.adminTable tbody tr:last-child td) {
    border-bottom: none;
  }

  .adminPage :global(.adminTable tbody tr:nth-child(even)) {
    background: rgba(0, 0, 0, 0.02);
  }

  .adminPage :global(.adminTable tbody tr:hover) {
    background: rgba(72, 196, 255, 0.07);
  }

  .adminPage :global(.adminTable a) {
    color: var(--admin-accent);
    font-weight: 600;
    text-decoration: none;
  }

  .adminPage :global(.adminTable a:hover) {
    text-decoration: underline;
  }

  .adminPage :global(.adminPendingActions) {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    flex-wrap: wrap;
    white-space: normal;
  }

  .adminPage :global(.adminPendingTrash) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.32rem;
    margin: 0;
    border: none;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    border-radius: 8px;
    line-height: 0;
    transition:
      color 0.15s ease,
      background 0.15s ease;
  }

  .adminPage :global(.adminPendingTrash:hover) {
    color: #b71c1c;
    background: rgba(183, 28, 28, 0.12);
  }

  .adminPage :global(.adminPendingTrash:focus-visible) {
    outline: 2px solid var(--admin-accent);
    outline-offset: 2px;
  }

  .adminPage :global(.adminTable--members tbody tr[data-admin-member-href]) {
    cursor: pointer;
  }

  .adminPage :global(.adminTable--members tbody tr[data-admin-member-href]:focus-visible) {
    outline: 2px solid rgba(28, 95, 118, 0.45);
    outline-offset: -2px;
  }

  .adminPage :global(.adminTable--members tbody tr[data-admin-member-href]:hover) {
    background: rgba(72, 196, 255, 0.1);
  }

  .adminShellFooter {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 1rem;
    padding: 0.65rem 1.25rem;
    border-top: 1px solid var(--admin-border);
    background: var(--admin-surface-muted);
  }

  .adminSignOutForm {
    margin: 0;
  }

  .adminPager {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    flex-wrap: wrap;
    gap: 0.65rem 1rem;
    margin-top: 1rem;
    padding-top: 0.75rem;
    border-top: 1px dashed var(--admin-border);
    font-size: 0.88rem;
    color: var(--muted);
  }

  .adminPager span {
    min-width: 8rem;
    text-align: center;
    color: var(--admin-text);
    font-variant-numeric: tabular-nums;
  }

  /**
   * Overview content is injected via innerHTML — scoped Astro CSS does not apply to it.
   * Use `.adminOverviewMount :global(...)` so KPIs, sections, and tables pick up styles.
   */
  .adminOverviewMount :global(.adminKpiRow) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(9.5rem, 1fr));
    gap: 0.85rem 1rem;
    margin: 0 0 1.75rem;
  }

  .adminOverviewMount :global(.adminKpi) {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 0.35rem;
    min-height: 4.25rem;
    padding: 0.85rem 1rem 0.9rem 1rem;
    text-align: left;
    background: linear-gradient(165deg, rgba(255, 255, 255, 0.92) 0%, var(--admin-surface-muted) 100%);
    border: 1px solid var(--admin-border);
    border-radius: var(--admin-radius-sm);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.04);
  }

  .adminOverviewMount :global(.adminKpi--pending) {
    border-left: 3px solid rgba(176, 120, 0, 0.88);
  }

  .adminOverviewMount :global(.adminKpi--activeYear) {
    border-left: 3px solid rgba(34, 120, 80, 0.85);
  }

  .adminOverviewMount :global(.adminKpi--directory) {
    border-left: 3px solid rgba(28, 95, 118, 0.55);
  }

  .adminOverviewMount :global(.adminKpiValue) {
    display: block;
    font-size: 1.5rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--admin-text);
  }

  .adminOverviewMount :global(.adminKpiLabel) {
    display: block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    line-height: 1.35;
    max-width: 14rem;
  }

  .adminOverviewMount :global(.adminOverviewSection) {
    margin: 0 0 1.65rem;
  }

  .adminOverviewMount :global(.adminOverviewSection:last-child) {
    margin-bottom: 0;
  }

  .adminOverviewMount :global(.adminOverviewHeading) {
    margin: 0 0 0.65rem;
    padding-bottom: 0.45rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--muted);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .adminOverviewMount :global(.adminStatusPill) {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.25;
    border: 1px solid transparent;
  }

  .adminOverviewMount :global(.adminStatusPill--active) {
    background: rgba(34, 120, 80, 0.12);
    border-color: rgba(34, 120, 80, 0.28);
    color: rgba(18, 75, 50, 0.95);
  }

  .adminOverviewMount :global(.adminStatusPill--pending) {
    background: rgba(200, 130, 0, 0.12);
    border-color: rgba(180, 110, 0, 0.28);
    color: rgba(90, 55, 0, 0.95);
  }

  .adminOverviewMount :global(.adminStatusPill--neutral) {
    background: rgba(0, 0, 0, 0.04);
    border-color: var(--admin-border);
    color: var(--muted);
    text-transform: none;
    font-weight: 600;
    font-size: 0.74rem;
  }

  .adminOverviewMount :global(.adminHint) {
    margin: 0;
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.5;
  }

  .adminDialog {
    padding: 0;
    border: none;
    border-radius: var(--admin-radius);
    max-width: min(440px, calc(100vw - 2rem));
    box-shadow: var(--shadow);
    background: var(--admin-surface);
  }

  .adminDialog::backdrop {
    background: rgba(15, 25, 35, 0.45);
    backdrop-filter: blur(2px);
  }

  :global(.adminEmailExportDialog) {
    padding: 1.25rem 1.35rem 1.5rem;
