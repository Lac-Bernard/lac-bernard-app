---
import MemberAppLayout from '../../layouts/MemberAppLayout.astro';
import MemberSessionHeroMeta from './MemberSessionHeroMeta.astro';
import {
	memberCopy,
	memberPaths,
	membershipTierLabel,
	type MemberLocale,
} from '../../lib/members/i18n';
import type { MemberAccountPayload } from '../../lib/members/accountData';
import { formatMemberPrimaryName } from '../../lib/members/memberDisplayName';
import { membershipCentsForTier } from '../../lib/membership/stripeCheckout';

interface Props {
	locale: MemberLocale;
	email: string;
	currentYear: number;
	accountData: MemberAccountPayload;
	checkoutFlash?: 'success' | 'cancelled' | null;
}

const { locale, email, currentYear, accountData, checkoutFlash = null } = Astro.props;
const t = memberCopy[locale];
const paths = memberPaths[locale];
const { member, currentMemberships, historicalMemberships } = accountData;

function membershipRows(rows: typeof currentMemberships) {
	return rows.map((row) => ({
		...row,
		tierLabel: membershipTierLabel(row.tier, locale),
	}));
}

const thisYearMembership = currentMemberships.find((m) => m.year === currentYear) ?? null;
const hasActiveCurrentYear = thisYearMembership?.status === 'active';
const pendingThisYear =
	thisYearMembership?.status === 'pending' ? thisYearMembership : null;
const thisYearTierLabel = thisYearMembership
	? membershipTierLabel(thisYearMembership.tier, locale)
	: '';

const futureRows = membershipRows(currentMemberships.filter((m) => m.year > currentYear));
const historyRows = membershipRows(historicalMemberships);

const activeTitle = t.statusActiveTitle.replace('{{year}}', String(currentYear));
const inactiveTitle = t.statusInactiveTitle.replace('{{year}}', String(currentYear));
const pendingTitle = t.statusPendingTitle.replace('{{year}}', String(currentYear));

const interacMail = `mailto:${t.interacEmail}`;
const membershipMail = `mailto:${t.membershipEmail}`;

const pendingFeeCents =
	pendingThisYear ? membershipCentsForTier(pendingThisYear.tier) : null;
const pendingMembershipFeeCad =
	pendingFeeCents != null ? (pendingFeeCents / 100).toFixed(2) : '0.00';

const activeFeeCents =
	thisYearMembership?.status === 'active'
		? membershipCentsForTier(thisYearMembership.tier)
		: null;
const activeMembershipFeeCad =
	activeFeeCents != null ? (activeFeeCents / 100).toFixed(2) : '0.00';

const activeYearScope = t.statusActiveYearScope.replace('{{year}}', String(currentYear));

const showMemberActions = Boolean(member);
const hasLakeAddress = Boolean(
	member &&
		member.lake_civic_number?.trim() &&
		member.lake_street_name?.trim(),
);
const lakeAddressLine =
	member?.lake_civic_number?.trim() && member?.lake_street_name?.trim()
		? `${member.lake_civic_number.trim()} ${member.lake_street_name.trim()}`
		: '';
const tierGeneralExplainerWithAddressResolved = lakeAddressLine
	? t.tierGeneralExplainerWithAddress.replace('{{lakeAddress}}', lakeAddressLine)
	: t.tierGeneralExplainer;

const generalCents = membershipCentsForTier('general');
const associateCents = membershipCentsForTier('associate');
const generalFeeCad =
	generalCents != null ? (generalCents / 100).toFixed(2) : '0.00';
const associateFeeCad =
	associateCents != null ? (associateCents / 100).toFixed(2) : '0.00';

const displayEmail = member ? (member.primary_email?.trim() || email) : '';
const memberPrimaryNameOnly = member ? formatMemberPrimaryName(member) : '';
const secondaryContactFirstName = member?.secondary_first_name?.trim() ?? '';
const secondaryContactLastName = member?.secondary_last_name?.trim() ?? '';
const secondaryContactEmail = member?.secondary_email?.trim() ?? '';
const secondaryContactPhone = member?.secondary_phone?.trim() ?? '';
const hasSecondaryContactInfo = Boolean(
	secondaryContactFirstName || secondaryContactLastName || secondaryContactEmail || secondaryContactPhone,
);
---

<MemberAppLayout
  lang={locale}
  title={t.homeTitle}
  description={t.homeDescription}
  heroTitle={t.homeHero}
>
  {email ? (
    <MemberSessionHeroMeta slot="hero-meta" locale={locale} email={email} signInRedirect={paths.signIn} />
  ) : null}
  <section class="section">
    <div class="container prose memberHomeProse">
      {checkoutFlash === 'success' && (
        <p class="checkoutBanner checkoutBannerSuccess" role="status">{t.checkoutSuccessBanner}</p>
      )}
      {checkoutFlash === 'cancelled' && (
        <p class="checkoutBanner checkoutBannerCancelled" role="status">{t.checkoutCancelledBanner}</p>
      )}

      {
        !member ? (
          <>
            <p class="muted">{t.noMemberForEmail}</p>
            <p>
              <a class="profileEditLink" href={`${paths.join}?next=${encodeURIComponent(paths.account)}`}>
                {t.linkCreateProfile}
              </a>
            </p>
          </>
        ) : (
          <>
            <div class="memberSummaryCard">
              <div class="memberSummaryHeader">
                <div class="memberSummaryIdentity">
                  <p class="memberSummaryName">{memberPrimaryNameOnly}</p>
                  <p class="memberSummaryEmail">{displayEmail}</p>
                </div>
                <a class="profileEditLink memberSummaryEdit" href={paths.edit}>{t.linkEditProfile}</a>
              </div>
              <div class="memberSummarySections">
                <section class="memberSummarySection" aria-labelledby="member-summary-info">
                  <h2 id="member-summary-info" class="memberSummarySectionTitle">{t.profileSectionPrimaryMember}</h2>
                  <dl class="memberSummaryDl">
                    <div class="memberSummaryDlRow">
                      <dt>{t.profileSignInEmail}</dt>
                      <dd>{displayEmail || t.homeAddressNotOnFile}</dd>
                    </div>
                    <div class="memberSummaryDlRow">
                      <dt>{t.profilePrimaryPhone}</dt>
                      <dd>{member?.primary_phone?.trim() || t.homeAddressNotOnFile}</dd>
                    </div>
                  </dl>
                </section>

                {hasSecondaryContactInfo && (
                  <section class="memberSummarySection" aria-labelledby="member-summary-secondary-contact">
                    <h2 id="member-summary-secondary-contact" class="memberSummarySectionTitle">{t.profileSectionSecondaryMember}</h2>
                    <dl class="memberSummaryDl">
                      <div class="memberSummaryDlRow">
                        <dt>{t.profileSecondaryFirstName}</dt>
                        <dd>{secondaryContactFirstName || t.homeAddressNotOnFile}</dd>
                      </div>
                      <div class="memberSummaryDlRow">
                        <dt>{t.profileSecondaryLastName}</dt>
                        <dd>{secondaryContactLastName || t.homeAddressNotOnFile}</dd>
                      </div>
                      <div class="memberSummaryDlRow">
                        <dt>{t.profileSecondaryEmail}</dt>
                        <dd>{secondaryContactEmail || t.homeAddressNotOnFile}</dd>
                      </div>
                      <div class="memberSummaryDlRow">
                        <dt>{t.profileSecondaryPhone}</dt>
                        <dd>{secondaryContactPhone || t.homeAddressNotOnFile}</dd>
                      </div>
                    </dl>
                  </section>
                )}

                <section class="memberSummarySection" aria-labelledby="member-summary-lake">
                  <h2 id="member-summary-lake" class="memberSummarySectionTitle">{t.profileSectionLake}</h2>
                  <p class="memberSummarySectionHelp">{t.profileLakeDisplayHelp}</p>
                  <dl class="memberSummaryDl">
                    <div class="memberSummaryDlRow">
                      <dt>{t.profileLakeCivic}</dt>
                      <dd>{member?.lake_civic_number?.trim() || t.homeAddressNotOnFile}</dd>
                    </div>
                    <div class="memberSummaryDlRow">
                      <dt>{t.profileLakeStreet}</dt>
                      <dd>{member?.lake_street_name?.trim() || t.homeAddressNotOnFile}</dd>
                    </div>
                  </dl>
                </section>
              </div>
            </div>

            {hasActiveCurrentYear ? (
              <div class="statusCard statusCardActive" role="status">
                <div class="statusActiveHead">
                  <div class="statusActiveMark" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M20 6 9 17l-5-5" />
                    </svg>
                  </div>
                  <h2 class="statusTitle">{activeTitle}</h2>
                </div>
                <div class="statusCardBody statusCardBodyActive">
                  <p class="statusActiveScope">{activeYearScope}</p>
                  <div class="activeTierSummary">
                    <p class="tierLegend">{t.statusActiveTierLabel}</p>
                    <div class="activeTierTile">
                      <div class="activeTierTileRow">
                        <span class="activeTierName">{thisYearTierLabel}</span>
                        <span class="activeTierFee">{activeMembershipFeeCad} CAD</span>
                      </div>
                      {thisYearMembership?.tier === 'general' && (
                        <div class="activeTierVote">
                          <p class="activeTierVoteLabel">{t.statusActiveGeneralVoteLabel}</p>
                          <p class="activeTierVoteAddress">{lakeAddressLine || t.homeAddressNotOnFile}</p>
                        </div>
                      )}
                    </div>
                  </div>
                  {futureRows.length > 0 && (
                    <p class="statusActivePrepaid">
                      {t.statusActivePrepaidTeaser.replace('{{count}}', String(futureRows.length))}
                    </p>
                  )}
                </div>
              </div>
            ) : pendingThisYear ? (
              <div class="statusCard statusCardPending" role="status">
                <div class="statusPendingHead">
                  <div class="statusPendingMark" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10" />
                      <polyline points="12 6 12 12 16 14" />
                    </svg>
                  </div>
                  <h2 class="statusTitle">{pendingTitle}</h2>
                </div>
                <div class="statusCardBody statusCardBodyPending">
                  <p class="statusPendingLead">{t.statusPendingLead}</p>

                  <div class="pendingTierSummary">
                    <p class="tierLegend">{t.statusActiveTierLabel}</p>
                    <div class="pendingTierTile">
                      <div class="pendingTierTileRow">
                        <span class="pendingTierName">{thisYearTierLabel}</span>
                        <span class="pendingTierFee">{pendingMembershipFeeCad} CAD</span>
                      </div>
                    </div>
                  </div>

                  <div class="payPrimary">
                    <button type="button" class="btnPrimary payCardBtn payCardBtnFull" id="open-checkout-modal">
                      {t.payWithCard}
                    </button>
                  </div>

                  <dialog id="checkout-modal" class="checkoutModal" aria-labelledby="checkout-modal-title">
                    <div class="checkoutModalInner">
                      <form id="checkout-modal-form" class="checkoutModalForm" data-membership-id={pendingThisYear.id}>
                        <div class="checkoutModalScroll">
                          <h2 id="checkout-modal-title" class="checkoutModalHeading">{t.checkoutModalTitle}</h2>
                          <dl class="checkoutModalSummary">
                            <div class="checkoutModalSummaryRow">
                              <dt>{t.checkoutModalMembershipLabel}</dt>
                              <dd>{thisYearTierLabel}</dd>
                            </div>
                            <div class="checkoutModalSummaryRow">
                              <dt>{t.checkoutModalFeeLabel}</dt>
                              <dd>{pendingMembershipFeeCad} CAD</dd>
                            </div>
                          </dl>
                          <div class="checkoutModalField donationRow">
                            <label class="donationLabel" for="modal-donation">{t.donationLabel}</label>
                            <input
                              type="number"
                              class="donationInput checkoutModalInput"
                              id="modal-donation"
                              name="donation"
                              min="0"
                              max="50000"
                              step="0.01"
                              placeholder="0"
                              inputmode="decimal"
                              aria-describedby="modal-donation-hint"
                            />
                            <p id="modal-donation-hint" class="stripeNote checkoutModalHint">{t.donationHint}</p>
                          </div>
                          <div class="checkoutModalField donationNoteRow">
                            <label class="donationLabel" for="modal-donation-note">{t.donationNoteLabel}</label>
                            <textarea
                              class="donationNoteInput"
                              id="modal-donation-note"
                              name="donationNote"
                              rows="3"
                              maxlength="500"
                              aria-describedby="modal-donation-note-hint"
                            ></textarea>
                            <p id="modal-donation-note-hint" class="stripeNote checkoutModalHint">{t.donationNoteHint}</p>
                          </div>
                        </div>
                        <p id="pay-checkout-message" class="actionMessage checkoutModalError" role="status" aria-live="polite"></p>
                        <div class="checkoutModalActions">
                          <button type="button" class="btnGhost checkoutModalBtnSecondary" id="checkout-modal-cancel">
                            {t.checkoutModalCancel}
                          </button>
                          <button type="submit" class="btnPrimary checkoutModalBtnPrimary" id="checkout-modal-submit">
                            {t.checkoutModalContinue}
                          </button>
                        </div>
                      </form>
                    </div>
                  </dialog>

                  <div class="payAlt">
                    <h3 class="payAltTitle">{t.otherPaymentTitle}</h3>
                    <div class="payMethodGrid">
                      <div class="payMethodCard">
                        <div class="payMethodCardTitle">{t.payInteracTitle}</div>
                        <p class="payMethodCardBody">
                          {t.payInteracBeforeLink}
                          <a href={interacMail}>{t.interacEmail}</a>
                          {t.payInteracAfterLink}
                        </p>
                      </div>
                      <div class="payMethodCard">
                        <div class="payMethodCardTitle">{t.payChequeTitle}</div>
                        <p class="payMethodCardBody payAddress">{t.payChequeAddress}</p>
                      </div>
                      <div class="payMethodCard">
                        <div class="payMethodCardTitle">{t.payCashTitle}</div>
                        <p class="payMethodCardBody">
                          {t.payCashBeforeLink}
                          <a href={membershipMail}>{t.membershipEmail}</a>
                          {t.payCashAfterLink}
                        </p>
                      </div>
                    </div>
                  </div>

                  <div class="cancelRow">
                    <button type="button" class="btnGhost cancelPendingBtn" id="cancel-pending-btn" data-membership-id={pendingThisYear.id}>
                      {t.cancelPending}
                    </button>
                    <p id="cancel-pending-message" class="actionMessage" role="status" aria-live="polite"></p>
                  </div>
                </div>
              </div>
            ) : (
              <div class="statusCard statusCardInactive" role="status">
                <div class="statusInactiveHead">
                  <div class="statusInactiveMark" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                      <line x1="16" y1="2" x2="16" y2="6" />
                      <line x1="8" y1="2" x2="8" y2="6" />
                      <line x1="3" y1="10" x2="21" y2="10" />
                    </svg>
                  </div>
                  <h2 class="statusTitle">{inactiveTitle}</h2>
                </div>
                <div class="statusCardBody statusCardBodyInactive">
                  <p class="statusLead">{t.statusInactiveLead}</p>
                  <ul class="statusSteps">
                    <li>{t.statusInactiveStep1}</li>
                    <li>{t.statusInactiveStep2}</li>
                    <li>{t.statusInactiveStep3}</li>
                  </ul>

                  <form id="create-pending-form" class="createPendingForm">
                    <fieldset class="tierFieldset">
                      <legend class="tierLegend">{t.tierChoiceLegend}</legend>
                      <div class="tierGrid">
                        <label class="tierOption tierOptionTile">
                          <input
                            type="radio"
                            name="tier"
                            value="general"
                            checked={hasLakeAddress}
                            disabled={!hasLakeAddress}
                            title={!hasLakeAddress ? t.tierGeneralBlockedLead : undefined}
                          />
                          <span class="tierOptionBody">
                            <span class="tierOptionTitleRow">
                              <span class="tierOptionTitle">{t.tierGeneral}</span>
                              <span class="tierOptionPriceBadge">{generalFeeCad} CAD</span>
                            </span>
                            <span class="tierOptionExplainer">
                              {hasLakeAddress ? tierGeneralExplainerWithAddressResolved : t.tierGeneralExplainer}
                            </span>
                          </span>
                        </label>
                        <label class="tierOption tierOptionTile">
                          <input type="radio" name="tier" value="associate" checked={!hasLakeAddress} />
                          <span class="tierOptionBody">
                            <span class="tierOptionTitleRow">
                              <span class="tierOptionTitle">{t.tierAssociate}</span>
                              <span class="tierOptionPriceBadge">{associateFeeCad} CAD</span>
                            </span>
                            <span class="tierOptionExplainer">{t.tierAssociateExplainer}</span>
                          </span>
                        </label>
                      </div>
                    </fieldset>
                    {!hasLakeAddress && (
                      <p class="tierBlockedNote">
                        {t.tierGeneralBlockedLead}{' '}
                        <a class="profileEditLink" href={paths.edit}>{t.linkEditProfile}</a>
                      </p>
                    )}
                    <button type="submit" class="btnPrimary createPendingSubmitBtn" id="create-pending-submit">{t.createPendingSubmit}</button>
                    <p id="create-pending-message" class="actionMessage" role="status" aria-live="polite"></p>
                  </form>
                </div>
              </div>
            )}

            {futureRows.length > 0 && (
              <section
                class="memberRecordsCard memberRecordsCardPrepaid"
                aria-labelledby="member-prepaid-heading"
              >
                <h2 id="member-prepaid-heading" class="memberRecordsTitle">
                  {t.membershipPrepaidSection}
                </h2>
                <p class="memberRecordsLead">{t.membershipPrepaidLead}</p>
                <div class="memberRecordsTableScroll">
                  <table class="memberRecordsTable">
                    <thead>
                      <tr>
                        <th scope="col">{t.membershipTableYear}</th>
                        <th scope="col">{t.membershipTableType}</th>
                      </tr>
                    </thead>
                    <tbody>
                      {futureRows.map((row) => (
                        <tr>
                          <td class="memberRecordsCellYear">{row.year}</td>
                          <td>{row.tierLabel}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </section>
            )}

            {historyRows.length > 0 && (
              <section
                class="memberRecordsCard memberRecordsCardHistory"
                aria-labelledby="member-history-heading"
              >
                <h2 id="member-history-heading" class="memberRecordsTitle">
                  {t.membershipHistorySection}
                </h2>
                <p class="memberRecordsLead memberRecordsLeadMuted">{t.membershipHistoryLead}</p>
                <div class="memberRecordsTableScroll">
                  <table class="memberRecordsTable">
                    <thead>
                      <tr>
                        <th scope="col">{t.membershipTableYear}</th>
                        <th scope="col">{t.membershipTableType}</th>
                      </tr>
                    </thead>
                    <tbody>
                      {historyRows.map((row) => (
                        <tr>
                          <td class="memberRecordsCellYear">{row.year}</td>
                          <td>{row.tierLabel}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </section>
            )}
          </>
        )
      }
    </div>
  </section>
</MemberAppLayout>

{showMemberActions && (
  <script
    define:vars={{
      errNetwork: t.errorNetwork,
      errUnauthorized: t.pendingCreateErrorUnauthorized,
      errAlreadyActive: t.pendingCreateErrorAlreadyActive,
      errAlreadyPending: t.pendingCreateErrorAlreadyPending,
      errCreateGeneric: t.pendingCreateErrorGeneric,
      errCancelGeneric: t.pendingCancelErrorGeneric,
      errCancelNotFound: t.pendingCancelErrorNotFound,
      memberLocale: locale,
      errCheckoutGeneric: t.checkoutErrorGeneric,
      errCheckoutStripeMisconfigured: t.checkoutStripeMisconfigured,
      errCheckoutInvalidDonation: t.checkoutInvalidDonation,
      errCheckoutInvalidDonationNote: t.checkoutInvalidDonationNote,
      errNoLake: t.pendingCreateErrorNoLakeAddress,
      errGeneralTaken: t.pendingCreateErrorGeneralAddressTaken,
    }}
  >
    function createErrorMessage(code) {
      if (code === 'unauthorized') return errUnauthorized;
      if (code === 'already_active') return errAlreadyActive;
      if (code === 'already_pending') return errAlreadyPending;
      if (code === 'no_lake_address') return errNoLake;
      if (code === 'general_address_taken') return errGeneralTaken;
      return errCreateGeneric;
    }

    const createForm = document.getElementById('create-pending-form');
    const createMsg = document.getElementById('create-pending-message');
    const createSubmit = document.getElementById('create-pending-submit');

    createForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!createMsg || !createSubmit) return;
      createMsg.textContent = '';
      createSubmit.setAttribute('disabled', 'true');
      const fd = new FormData(createForm);
      const tier = String(fd.get('tier') ?? '');
      try {
        const res = await fetch('/api/membership/create-pending', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ tier }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          createMsg.textContent = createErrorMessage(data.error) || errCreateGeneric;
          return;
        }
        window.location.reload();
      } catch {
        createMsg.textContent = errNetwork;
      } finally {
        createSubmit.removeAttribute('disabled');
      }
    });

    const cancelBtn = document.getElementById('cancel-pending-btn');
    const cancelMsg = document.getElementById('cancel-pending-message');

    cancelBtn?.addEventListener('click', async () => {
      if (!cancelMsg || !cancelBtn) return;
      const id = cancelBtn.getAttribute('data-membership-id');
      if (!id) return;
      cancelMsg.textContent = '';
      cancelBtn.setAttribute('disabled', 'true');
      try {
        const res = await fetch('/api/membership/cancel-pending', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ membershipId: id }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          cancelMsg.textContent =
            data.error === 'not_found' ? errCancelNotFound : errCancelGeneric;
          return;
        }
        window.location.reload();
      } catch {
        cancelMsg.textContent = errNetwork;
      } finally {
        cancelBtn.removeAttribute('disabled');
      }
    });

    const checkoutModal = document.getElementById('checkout-modal');
    const openCheckoutBtn = document.getElementById('open-checkout-modal');
    const checkoutModalForm = document.getElementById('checkout-modal-form');
    const checkoutMsg = document.getElementById('pay-checkout-message');
    const checkoutSubmit = document.getElementById('checkout-modal-submit');
    const donationInput = document.getElementById('modal-donation');
    const donationNoteInput = document.getElementById('modal-donation-note');

    openCheckoutBtn?.addEventListener('click', () => {
      if (checkoutMsg) checkoutMsg.textContent = '';
      checkoutModalForm?.reset();
      checkoutModal?.showModal();
    });

    document.getElementById('checkout-modal-cancel')?.addEventListener('click', () => {
      checkoutModalForm?.reset();
      if (checkoutMsg) checkoutMsg.textContent = '';
      checkoutModal?.close();
    });

    checkoutModalForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!checkoutMsg || !checkoutSubmit || !checkoutModalForm) return;
      const membershipId = checkoutModalForm.getAttribute('data-membership-id');
      if (!membershipId) return;
      checkoutMsg.textContent = '';
      checkoutSubmit.setAttribute('disabled', 'true');
      let donationDollars = 0;
      if (donationInput) {
        const v = String(donationInput.value ?? '').trim();
        if (v === '') {
          donationDollars = 0;
        } else {
          const n = parseFloat(v);
          if (!Number.isFinite(n) || n < 0) {
            checkoutMsg.textContent = errCheckoutInvalidDonation;
            checkoutSubmit.removeAttribute('disabled');
            return;
          }
          donationDollars = n;
        }
      }
      const donationNote = donationNoteInput ? String(donationNoteInput.value ?? '').trim() : '';
      if (donationNote.length > 500) {
        checkoutMsg.textContent = errCheckoutInvalidDonationNote;
        checkoutSubmit.removeAttribute('disabled');
        return;
      }
      try {
        const res = await fetch('/api/membership/create-checkout-session', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            membershipId,
            donationDollars,
            donationNote,
            locale: memberLocale,
          }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          if (data.error === 'invalid_donation') {
            checkoutMsg.textContent = errCheckoutInvalidDonation;
          } else if (data.error === 'invalid_donation_note') {
            checkoutMsg.textContent = errCheckoutInvalidDonationNote;
          } else if (data.error === 'no_lake_address') {
            checkoutMsg.textContent = errNoLake;
          } else if (data.error === 'general_address_taken') {
            checkoutMsg.textContent = errGeneralTaken;
          } else if (data.error === 'stripe_misconfigured') {
            checkoutMsg.textContent = errCheckoutStripeMisconfigured;
          } else {
            checkoutMsg.textContent = errCheckoutGeneric;
          }
          return;
        }
        if (typeof data.url === 'string' && data.url) {
          window.location.assign(data.url);
          return;
        }
        checkoutMsg.textContent = errCheckoutGeneric;
      } catch {
        checkoutMsg.textContent = errNetwork;
      } finally {
        checkoutSubmit.removeAttribute('disabled');
      }
    });
