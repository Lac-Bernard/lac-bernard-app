---
import MemberAppLayout from '../../layouts/MemberAppLayout.astro';
import {
	memberCopy,
	memberPaths,
	membershipTierLabel,
	type MemberLocale,
} from '../../lib/members/i18n';
import type { MemberAccountPayload } from '../../lib/members/accountData';
import { membershipCentsForTier } from '../../lib/membership/stripeCheckout';

interface Props {
	locale: MemberLocale;
	email: string;
	currentYear: number;
	accountData: MemberAccountPayload;
	checkoutFlash?: 'success' | 'cancelled' | null;
}

const { locale, email, currentYear, accountData, checkoutFlash = null } = Astro.props;
const t = memberCopy[locale];
const paths = memberPaths[locale];
const heroSubtitle = email ? `${t.signedInAs} ${email}` : '';
const { member, currentMemberships, historicalMemberships } = accountData;

const intro = t.homeIntro.replace('{{year}}', String(currentYear));

function membershipRows(rows: typeof currentMemberships) {
	return rows.map((row) => ({
		...row,
		tierLabel: membershipTierLabel(row.tier, locale),
	}));
}

const thisYearMembership = currentMemberships.find((m) => m.year === currentYear) ?? null;
const hasActiveCurrentYear = thisYearMembership?.status === 'active';
const pendingThisYear =
	thisYearMembership?.status === 'pending' ? thisYearMembership : null;
const thisYearTierLabel = thisYearMembership
	? membershipTierLabel(thisYearMembership.tier, locale)
	: '';

const futureRows = membershipRows(currentMemberships.filter((m) => m.year > currentYear));
const historyRows = membershipRows(historicalMemberships);

const activeTitle = t.statusActiveTitle.replace('{{year}}', String(currentYear));
const inactiveTitle = t.statusInactiveTitle.replace('{{year}}', String(currentYear));
const pendingTitle = t.statusPendingTitle.replace('{{year}}', String(currentYear));

const interacMail = `mailto:${t.interacEmail}`;
const membershipMail = `mailto:${t.membershipEmail}`;

const pendingFeeCents =
	pendingThisYear ? membershipCentsForTier(pendingThisYear.tier) : null;
const pendingMembershipFeeCad =
	pendingFeeCents != null ? (pendingFeeCents / 100).toFixed(2) : '0.00';

const showMemberActions = Boolean(member);
---

<MemberAppLayout
  lang={locale}
  title={t.homeTitle}
  description={t.homeDescription}
  heroAriaLabel={t.homeHero}
  heroTitle={t.homeHero}
  heroSubtitle={heroSubtitle}
>
  <section class="section">
    <div class="container prose">
      <p>{intro}</p>

      {checkoutFlash === 'success' && (
        <p class="checkoutBanner checkoutBannerSuccess" role="status">{t.checkoutSuccessBanner}</p>
      )}
      {checkoutFlash === 'cancelled' && (
        <p class="checkoutBanner checkoutBannerCancelled" role="status">{t.checkoutCancelledBanner}</p>
      )}

      {
        !member ? (
          <>
            <p class="muted">{t.noMemberForEmail}</p>
            <p>
              <a class="profileEditLink" href={`${paths.join}?next=${encodeURIComponent(paths.account)}`}>
                {t.linkCreateProfile}
              </a>
            </p>
          </>
        ) : (
          <>
            <p class="profileEditRow">
              <a class="profileEditLink" href={paths.edit}>{t.linkEditProfile}</a>
            </p>
            <p class="memberName">
              {member.first_name ? `${member.first_name} ` : ''}
              {member.last_name}
            </p>

            {hasActiveCurrentYear ? (
              <div class="statusCard statusCardActive" role="status">
                <div class="statusActiveMark" aria-hidden="true">✓</div>
                <div class="statusCardBody">
                  <h2 class="statusTitle">{activeTitle}</h2>
                  <p class="statusTier">
                    <span class="statusTierLabel">{t.statusActiveTierLabel}</span>
                    {thisYearTierLabel}
                  </p>
                </div>
              </div>
            ) : pendingThisYear ? (
              <div class="statusCard statusCardPending" role="status">
                <h2 class="statusTitle">{pendingTitle}</h2>
                <p class="statusPendingLead">{t.statusPendingLead}</p>
                <p class="statusTier">
                  <span class="statusTierLabel">{t.statusActiveTierLabel}</span>
                  {thisYearTierLabel}
                </p>

                <div class="payPrimary">
                  <button type="button" class="btnPrimary payCardBtn" id="open-checkout-modal">
                    {t.payWithCard}
                  </button>
                </div>

                <dialog id="checkout-modal" class="checkoutModal" aria-labelledby="checkout-modal-title">
                  <div class="checkoutModalInner">
                    <h2 id="checkout-modal-title" class="checkoutModalHeading">{t.checkoutModalTitle}</h2>
                    <dl class="checkoutModalSummary">
                      <div class="checkoutModalSummaryRow">
                        <dt>{t.checkoutModalMembershipLabel}</dt>
                        <dd>{thisYearTierLabel}</dd>
                      </div>
                      <div class="checkoutModalSummaryRow">
                        <dt>{t.checkoutModalFeeLabel}</dt>
                        <dd>
                          {pendingMembershipFeeCad} CAD
                        </dd>
                      </div>
                    </dl>
                    <form id="checkout-modal-form" data-membership-id={pendingThisYear.id}>
                      <div class="donationRow">
                        <label class="donationLabel" for="modal-donation">{t.donationLabel}</label>
                        <input
                          type="number"
                          class="donationInput"
                          id="modal-donation"
                          name="donation"
                          min="0"
                          max="50000"
                          step="0.01"
                          placeholder="0"
                          inputmode="decimal"
                          aria-describedby="modal-donation-hint"
                        />
                        <p id="modal-donation-hint" class="stripeNote">{t.donationHint}</p>
                      </div>
                      <div class="donationNoteRow">
                        <label class="donationLabel" for="modal-donation-note">{t.donationNoteLabel}</label>
                        <textarea
                          class="donationNoteInput"
                          id="modal-donation-note"
                          name="donationNote"
                          rows="3"
                          maxlength="500"
                          aria-describedby="modal-donation-note-hint"
                        ></textarea>
                        <p id="modal-donation-note-hint" class="stripeNote">{t.donationNoteHint}</p>
                      </div>
                      <p id="pay-checkout-message" class="actionMessage checkoutModalError" role="status" aria-live="polite"></p>
                      <div class="checkoutModalActions">
                        <button type="button" class="btnGhost" id="checkout-modal-cancel">
                          {t.checkoutModalCancel}
                        </button>
                        <button type="submit" class="btnPrimary" id="checkout-modal-submit">
                          {t.checkoutModalContinue}
                        </button>
                      </div>
                    </form>
                  </div>
                </dialog>

                <div class="payAlt">
                  <h3 class="payAltTitle">{t.otherPaymentTitle}</h3>
                  <ul class="payList">
                    <li>
                      <span class="payMethodName">{t.payInteracTitle}</span>
                      <p class="payMethodBody">
                        {t.payInteracBeforeLink}
                        <a href={interacMail}>{t.interacEmail}</a>
                        {t.payInteracAfterLink}
                      </p>
                    </li>
                    <li>
                      <span class="payMethodName">{t.payChequeTitle}</span>
                      <p class="payMethodBody payAddress">{t.payChequeAddress}</p>
                    </li>
                    <li>
                      <span class="payMethodName">{t.payCashTitle}</span>
                      <p class="payMethodBody">
                        {t.payCashBeforeLink}
                        <a href={membershipMail}>{t.membershipEmail}</a>
                        {t.payCashAfterLink}
                      </p>
                    </li>
                  </ul>
                </div>

                <p class="formsHint">
                  {t.formsHintBefore}
                  <a href={paths.renewal}>{t.linkRenewal}</a>
                  {t.formsHintAfter}
                  <a href={paths.enrollment}>{t.linkEnrollment}</a>
                  {t.formsHintEnd}
                </p>

                <div class="cancelRow">
                  <button type="button" class="btnGhost cancelPendingBtn" id="cancel-pending-btn" data-membership-id={pendingThisYear.id}>
                    {t.cancelPending}
                  </button>
                  <p id="cancel-pending-message" class="actionMessage" role="status" aria-live="polite"></p>
                </div>
              </div>
            ) : (
              <div class="statusCard statusCardInactive">
                <h2 class="statusTitle">{inactiveTitle}</h2>
                <p class="statusLead">{t.statusInactiveLead}</p>

                <form id="create-pending-form" class="createPendingForm">
                  <fieldset class="tierFieldset">
                    <legend class="tierLegend">{t.tierChoiceLegend}</legend>
                    <label class="tierOption">
                      <input type="radio" name="tier" value="general" checked />
                      {t.tierGeneral}
                    </label>
                    <label class="tierOption">
                      <input type="radio" name="tier" value="associate" />
                      {t.tierAssociate}
                    </label>
                  </fieldset>
                  <button type="submit" class="btnPrimary" id="create-pending-submit">{t.createPendingSubmit}</button>
                  <p id="create-pending-message" class="actionMessage" role="status" aria-live="polite"></p>
                </form>

                <p class="formsHint">
                  {t.formsHintBefore}
                  <a href={paths.renewal}>{t.linkRenewal}</a>
                  {t.formsHintAfter}
                  <a href={paths.enrollment}>{t.linkEnrollment}</a>
                  {t.formsHintEnd}
                </p>
              </div>
            )}

            {futureRows.length > 0 && (
              <>
                <h2 class="sectionHeading">{t.membershipPrepaidSection}</h2>
                <p class="muted sectionLead">{t.membershipPrepaidLead}</p>
                <div class="tableWrap">
                  <table class="memberTable">
                    <thead>
                      <tr>
                        <th scope="col">{t.membershipTableYear}</th>
                        <th scope="col">{t.membershipTableType}</th>
                        <th scope="col">{t.membershipTableStatus}</th>
                      </tr>
                    </thead>
                    <tbody>
                      {futureRows.map((row) => (
                        <tr>
                          <td>{row.year}</td>
                          <td>{row.tierLabel}</td>
                          <td>{row.status === 'pending' ? t.membershipStatusPending : t.membershipStatusActive}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </>
            )}

            {historyRows.length > 0 && (
              <>
                <h2 class="sectionHeading">{t.membershipHistorySection}</h2>
                <div class="tableWrap">
                  <table class="memberTable">
                    <thead>
                      <tr>
                        <th scope="col">{t.membershipTableYear}</th>
                        <th scope="col">{t.membershipTableType}</th>
                        <th scope="col">{t.membershipTableStatus}</th>
                      </tr>
                    </thead>
                    <tbody>
                      {historyRows.map((row) => (
                        <tr>
                          <td>{row.year}</td>
                          <td>{row.tierLabel}</td>
                          <td>{row.status === 'pending' ? t.membershipStatusPending : t.membershipStatusActive}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </>
            )}
          </>
        )
      }

      <form method="POST" action="/api/auth/sign-out">
        <input type="hidden" name="redirect_to" value={paths.signIn} />
        <button type="submit" class="btnGhost">{t.signOut}</button>
      </form>
    </div>
  </section>
</MemberAppLayout>

{showMemberActions && (
  <script
    define:vars={{
      errNetwork: t.errorNetwork,
      errUnauthorized: t.pendingCreateErrorUnauthorized,
      errAlreadyActive: t.pendingCreateErrorAlreadyActive,
      errAlreadyPending: t.pendingCreateErrorAlreadyPending,
      errCreateGeneric: t.pendingCreateErrorGeneric,
      errCancelGeneric: t.pendingCancelErrorGeneric,
      errCancelNotFound: t.pendingCancelErrorNotFound,
      memberLocale: locale,
      errCheckoutGeneric: t.checkoutErrorGeneric,
      errCheckoutStripeMisconfigured: t.checkoutStripeMisconfigured,
      errCheckoutInvalidDonation: t.checkoutInvalidDonation,
      errCheckoutInvalidDonationNote: t.checkoutInvalidDonationNote,
    }}
  >
    function createErrorMessage(code) {
      if (code === 'unauthorized') return errUnauthorized;
      if (code === 'already_active') return errAlreadyActive;
      if (code === 'already_pending') return errAlreadyPending;
      return errCreateGeneric;
    }

    const createForm = document.getElementById('create-pending-form');
    const createMsg = document.getElementById('create-pending-message');
    const createSubmit = document.getElementById('create-pending-submit');

    createForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!createMsg || !createSubmit) return;
      createMsg.textContent = '';
      createSubmit.setAttribute('disabled', 'true');
      const fd = new FormData(createForm);
      const tier = String(fd.get('tier') ?? '');
      try {
        const res = await fetch('/api/membership/create-pending', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ tier }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          createMsg.textContent = createErrorMessage(data.error) || errCreateGeneric;
          return;
        }
        window.location.reload();
      } catch {
        createMsg.textContent = errNetwork;
      } finally {
        createSubmit.removeAttribute('disabled');
      }
    });

    const cancelBtn = document.getElementById('cancel-pending-btn');
    const cancelMsg = document.getElementById('cancel-pending-message');

    cancelBtn?.addEventListener('click', async () => {
      if (!cancelMsg || !cancelBtn) return;
      const id = cancelBtn.getAttribute('data-membership-id');
      if (!id) return;
      cancelMsg.textContent = '';
      cancelBtn.setAttribute('disabled', 'true');
      try {
        const res = await fetch('/api/membership/cancel-pending', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ membershipId: id }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          cancelMsg.textContent =
            data.error === 'not_found' ? errCancelNotFound : errCancelGeneric;
          return;
        }
        window.location.reload();
      } catch {
        cancelMsg.textContent = errNetwork;
      } finally {
        cancelBtn.removeAttribute('disabled');
      }
    });

    const checkoutModal = document.getElementById('checkout-modal');
    const openCheckoutBtn = document.getElementById('open-checkout-modal');
    const checkoutModalForm = document.getElementById('checkout-modal-form');
    const checkoutMsg = document.getElementById('pay-checkout-message');
    const checkoutSubmit = document.getElementById('checkout-modal-submit');
    const donationInput = document.getElementById('modal-donation');
    const donationNoteInput = document.getElementById('modal-donation-note');

    openCheckoutBtn?.addEventListener('click', () => {
      if (checkoutMsg) checkoutMsg.textContent = '';
      checkoutModalForm?.reset();
      checkoutModal?.showModal();
    });

    document.getElementById('checkout-modal-cancel')?.addEventListener('click', () => {
      checkoutModalForm?.reset();
      if (checkoutMsg) checkoutMsg.textContent = '';
      checkoutModal?.close();
    });

    checkoutModalForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!checkoutMsg || !checkoutSubmit || !checkoutModalForm) return;
      const membershipId = checkoutModalForm.getAttribute('data-membership-id');
      if (!membershipId) return;
      checkoutMsg.textContent = '';
      checkoutSubmit.setAttribute('disabled', 'true');
      let donationDollars = 0;
      if (donationInput) {
        const v = String(donationInput.value ?? '').trim();
        if (v === '') {
          donationDollars = 0;
        } else {
          const n = parseFloat(v);
          if (!Number.isFinite(n) || n < 0) {
            checkoutMsg.textContent = errCheckoutInvalidDonation;
            checkoutSubmit.removeAttribute('disabled');
            return;
          }
          donationDollars = n;
        }
      }
      const donationNote = donationNoteInput ? String(donationNoteInput.value ?? '').trim() : '';
      if (donationNote.length > 500) {
        checkoutMsg.textContent = errCheckoutInvalidDonationNote;
        checkoutSubmit.removeAttribute('disabled');
        return;
      }
      try {
        const res = await fetch('/api/membership/create-checkout-session', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            membershipId,
            donationDollars,
            donationNote,
            locale: memberLocale,
          }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          if (data.error === 'invalid_donation') {
            checkoutMsg.textContent = errCheckoutInvalidDonation;
          } else if (data.error === 'invalid_donation_note') {
            checkoutMsg.textContent = errCheckoutInvalidDonationNote;
          } else if (data.error === 'stripe_misconfigured') {
            checkoutMsg.textContent = errCheckoutStripeMisconfigured;
          } else {
            checkoutMsg.textContent = errCheckoutGeneric;
          }
          return;
        }
        if (typeof data.url === 'string' && data.url) {
          window.location.assign(data.url);
          return;
        }
        checkoutMsg.textContent = errCheckoutGeneric;
      } catch {
        checkoutMsg.textContent = errNetwork;
      } finally {
        checkoutSubmit.removeAttribute('disabled');
      }
    });
  </script>
)}

<style>
  .prose form {
    margin-top: 1.5rem;
  }

  .muted {
    color: var(--muted, #555);
  }

  .profileEditRow {
    margin: 0 0 0.75rem;
  }

  .profileEditLink {
    font-weight: 600;
    color: var(--color-accent, #1a5f4a);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .profileEditLink:hover {
    text-decoration-thickness: 2px;
  }

  .memberName {
    font-weight: 600;
    margin-bottom: 1.25rem;
  }

  .sectionHeading {
    font-size: 1.25rem;
    margin: 1.75rem 0 0.5rem;
  }

  .sectionLead {
    margin: 0 0 0.75rem;
    font-size: 0.95rem;
  }

  .statusCard {
    border-radius: 14px;
    padding: 1.35rem 1.35rem 1.25rem;
    margin-bottom: 1.5rem;
    border: 1px solid var(--border, rgba(0, 0, 0, 0.12));
  }

  .statusCardActive {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: rgba(22, 163, 74, 0.08);
    border-color: rgba(22, 163, 74, 0.35);
  }

  .statusActiveMark {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: rgba(22, 163, 74, 0.95);
    color: #fff;
    font-size: 1.35rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  .statusCardBody {
    min-width: 0;
  }

  .statusCardInactive {
    background: rgba(37, 99, 235, 0.04);
    border-color: rgba(37, 99, 235, 0.22);
  }

  .statusCardPending {
    background: rgba(217, 119, 6, 0.08);
    border-color: rgba(217, 119, 6, 0.35);
  }

  .statusCardPending .statusTitle {
    color: rgba(146, 64, 14, 0.98);
  }

  .statusPendingLead {
    margin: 0 0 1rem;
    color: var(--text, rgba(0, 0, 0, 0.88));
  }

  .statusTitle {
    margin: 0 0 0.5rem;
    font-size: 1.45rem;
    line-height: 1.2;
  }

  .statusCardInactive .statusTitle {
    color: rgba(30, 64, 175, 0.95);
  }

  .statusLead {
    margin: 0 0 1.25rem;
    color: var(--text, rgba(0, 0, 0, 0.88));
  }

  .statusTier {
    margin: 0 0 1.25rem;
    font-size: 1.1rem;
  }

  .statusTierLabel {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted, #555);
    margin-bottom: 0.2rem;
  }

  .createPendingForm {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .tierFieldset {
    margin: 0;
    padding: 0;
    border: none;
    min-width: 0;
  }

  .tierLegend {
    font-weight: 600;
    font-size: 1rem;
    margin-bottom: 0.5rem;
    padding: 0;
  }

  .tierOption {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.35rem;
    cursor: pointer;
    font-size: 1rem;
  }

  .tierOption input {
    width: 1.1rem;
    height: 1.1rem;
    accent-color: #2563eb;
  }

  .actionMessage {
    margin: 0.35rem 0 0;
    min-height: 1.25em;
    font-size: 0.95rem;
    color: var(--muted, #555);
  }

  .cancelRow {
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .cancelPendingBtn {
    margin-bottom: 0.25rem;
  }

  .payPrimary {
    margin-bottom: 1.5rem;
  }

  .checkoutModal {
    max-width: min(26rem, calc(100vw - 2rem));
    padding: 0;
    border: none;
    border-radius: 0.5rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
  }

  .checkoutModal::backdrop {
    background: rgba(0, 0, 0, 0.45);
  }

  .checkoutModalInner {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .checkoutModalHeading {
    margin: 0 0 1rem;
    font-size: 1.2rem;
    font-weight: 700;
  }

  .checkoutModalSummary {
    margin: 0 0 1.25rem;
    padding: 0.75rem 0.9rem;
    border-radius: 0.375rem;
    background: rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  .checkoutModalSummaryRow {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.35rem 1rem;
    align-items: baseline;
    font-size: 0.95rem;
  }

  .checkoutModalSummaryRow:not(:last-child) {
    margin-bottom: 0.5rem;
  }

  .checkoutModalSummaryRow dt {
    margin: 0;
    font-weight: 600;
    color: var(--muted, #555);
  }

  .checkoutModalSummaryRow dd {
    margin: 0;
    text-align: right;
    font-weight: 600;
  }

  .donationNoteRow {
    margin-bottom: 0.75rem;
  }

  .donationNoteInput {
    display: block;
    width: 100%;
    box-sizing: border-box;
    padding: 0.5rem 0.6rem;
    font-size: 0.95rem;
    line-height: 1.45;
    border: 1px solid rgba(0, 0, 0, 0.2);
    border-radius: 0.375rem;
    background: var(--bg, #fff);
    resize: vertical;
    min-height: 4.5rem;
  }

  .checkoutModalError {
    margin: 0.5rem 0 0.75rem;
  }

  .checkoutModalActions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    justify-content: flex-end;
    margin-top: 0.25rem;
  }

  .checkoutBanner {
    padding: 0.75rem 1rem;
    margin: 0 0 1.25rem;
    border-radius: 0.375rem;
    font-size: 0.95rem;
    line-height: 1.45;
  }

  .checkoutBannerSuccess {
    background: rgba(22, 163, 74, 0.12);
    border: 1px solid rgba(22, 163, 74, 0.35);
  }

  .checkoutBannerCancelled {
    background: rgba(234, 179, 8, 0.15);
    border: 1px solid rgba(202, 138, 4, 0.35);
  }

  .donationRow {
    margin-bottom: 0.75rem;
  }

  .donationLabel {
    display: block;
    font-weight: 600;
    margin-bottom: 0.35rem;
    font-size: 0.95rem;
  }

  .donationInput {
    display: block;
    width: 100%;
    max-width: 12rem;
    padding: 0.45rem 0.6rem;
    font-size: 1rem;
    border: 1px solid rgba(0, 0, 0, 0.2);
    border-radius: 0.375rem;
    background: var(--bg, #fff);
  }

  .payCardBtn:disabled {
    opacity: 0.72;
    cursor: not-allowed;
    transform: none;
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  }

  .payCardBtn:disabled:hover {
    background: #2563eb;
    transform: none;
  }

  .stripeNote {
    margin: 0.5rem 0 0;
    font-size: 0.9rem;
