---
import MemberAppLayout from '../../layouts/MemberAppLayout.astro';
import MemberSessionHeroMeta from './MemberSessionHeroMeta.astro';
import { memberCopy, memberPaths, type MemberLocale } from '../../lib/members/i18n';
import { getMembershipCalendarYear } from '../../lib/members/membershipYear';

interface Props {
	locale: MemberLocale;
	email: string;
	memberId: string;
}

const { locale, email, memberId } = Astro.props;
const t = memberCopy[locale];
const paths = memberPaths[locale];
const calendarYear = getMembershipCalendarYear();
const numberLocale = locale === 'fr' ? 'fr-CA' : 'en-CA';

const adminKeys = [
	'adminDetailTitle',
	'adminDetailSectionMemberships',
	'adminDetailPaymentsHeading',
	'adminBreadcrumbAria',
	'adminMemberPageTitleLoading',
	'adminRecordPaymentBtn',
	'adminPaymentHeading',
	'adminAmountLabel',
	'adminMethodLabel',
	'adminMethodEtransfer',
	'adminMethodCheque',
	'adminMethodCash',
	'adminMethodUnknown',
	'adminMethodStripe',
	'adminDateLabel',
	'adminPaymentReferenceLabel',
	'adminNotesLabel',
	'adminSubmitPaymentBtn',
	'adminPromoteBtn',
	'adminPromoteSuccess',
	'adminPromoteNoAccount',
	'adminSaveMemberBtn',
	'adminLoading',
	'adminErrorGeneric',
	'adminMemberSaved',
	'adminPaymentSaved',
	'adminSecondaryEmailLabel',
	'adminSecondaryFirstNameLabel',
	'adminSecondaryLastNameLabel',
	'adminSecondaryPhoneLabel',
	'adminSecondaryContactHelp',
	'adminNotesFieldLabel',
	'adminStatusMemberLabel',
	'adminStatusMemberOptionNew',
	'adminStatusMemberOptionVerified',
	'adminStatusMemberOptionDisabled',
	'adminStatusMemberFieldTitle',
	'adminPromoteAdminTitle',
	'adminUserIdLabel',
	'adminPrimaryEmailLabel',
  'membershipTableYear',
  'membershipTableType',
  'membershipTableStatus',
	'membershipStatusActive',
	'membershipStatusPending',
	'adminTableAmount',
	'adminTableDuesPortion',
	'adminTableDonationPortion',
	'adminPaymentPreviewMembership',
	'adminPaymentPreviewDonation',
	'adminTablePaymentDate',
	'adminDetailNoMemberships',
	'adminDetailPaymentsEmpty',
	'adminDetailFutureBadge',
	'adminDetailMembershipYearPicker',
	'adminDetailStandardFee',
	'adminDetailAmountMembership',
	'adminDetailAmountDonation',
	'adminDetailAmountTotal',
	'adminDetailPaymentSummaryTitle',
	'adminDetailBalanceDue',
	'adminDetailDuesPaidInFull',
	'adminDeletePaymentBtn',
	'adminDeletePaymentConfirm',
	'adminPaymentDeleted',
	'adminTableActions',
	'adminDetailNoMembershipForYear',
	'adminDetailDonationNoteLabel',
	'adminTablePaymentRef',
	'adminAddMembershipOpen',
	'adminAddMembershipDialogTitle',
	'adminAddMembershipSubmit',
	'adminAddMemberInitialPending',
	'adminAddMemberInitialPaid',
	'adminAddMemberErrorNoLake',
	'adminAddMemberErrorAddressTaken',
	'adminAddMemberErrorDuplicateYear',
	'adminMembershipYearLabel',
	'checkoutModalCancel',
	'profileSectionPrimaryMember',
	'profileSectionSecondaryMember',
	'profileShowSecondaryMember',
	'profileSecondaryMemberHelp',
	'profileLakeHelp',
	'profileSecondaryEmail',
] as const;

const adminStrings = Object.fromEntries(adminKeys.map((k) => [k, t[k as keyof typeof t]])) as Record<string, string>;

const tierLabels = { general: t.tierGeneral, associate: t.tierAssociate };
const adminMembersTabHref = `${paths.admin}?tab=members`;
---

<MemberAppLayout
  lang={locale}
  title={t.adminDetailTitle}
  description={t.adminDescription}
  heroTitle={t.adminMemberPageTitleLoading}
  alignHeroWithAdmin
>
  <nav slot="hero-breadcrumb" class="memberWorkspaceBreadcrumb" aria-label={t.adminBreadcrumbAria}>
    <div class="memberWorkspaceBreadcrumbList" role="list">
      <div role="listitem" class="memberWorkspaceBreadcrumbItem">
        <a href={paths.admin} class="memberWorkspaceBreadcrumbLink">{t.adminHero}</a>
      </div>
      <div role="listitem" class="memberWorkspaceBreadcrumbItem">
        <a href={adminMembersTabHref} class="memberWorkspaceBreadcrumbLink">{t.adminNavMembers}</a>
      </div>
    </div>
  </nav>
  <MemberSessionHeroMeta
    slot="hero-meta"
    locale={locale}
    email={email}
    signInRedirect={paths.signIn}
    variant="adminWorkspace"
  />
  <section class="section alt adminPage adminPageMemberDetail">
    <div class="container adminConsole">
      <div class="adminShell">
        <p id="admin-detail-status" class="adminStatus" aria-live="polite"></p>

        <div class="adminPanel adminCard adminPanel--profile">
          <form id="admin-member-detail-form" class="adminMemberForm">
            <div class="adminProfileSections">
              <fieldset class="adminProfileSection">
                <legend class="adminProfileLegend">{t.profileSectionPrimaryMember}</legend>
                <div class="adminFormGrid">
                  <label>{t.profileFirstName} <input type="text" id="admin-field-first_name" name="first_name" class="adminInput" /></label>
                  <label>{t.profileLastName} * <input type="text" id="admin-field-last_name" name="last_name" class="adminInput" required /></label>
                  <label>{t.adminPrimaryEmailLabel} <input type="email" id="admin-field-primary_email" name="primary_email" class="adminInput" /></label>
                  <label>{t.profilePrimaryPhone} <input type="text" id="admin-field-primary_phone" name="primary_phone" class="adminInput" /></label>
                </div>
              </fieldset>

              <div class="adminProfileSection">
                <p class="adminSectionHelp">{t.adminSecondaryContactHelp}</p>
                <div id="admin-detail-secondary-contact-fields" class="adminFormGrid">
                  <label>{t.adminSecondaryFirstNameLabel} <input type="text" id="admin-field-secondary_first_name" name="secondary_first_name" class="adminInput" /></label>
                  <label>{t.adminSecondaryLastNameLabel} <input type="text" id="admin-field-secondary_last_name" name="secondary_last_name" class="adminInput" /></label>
                  <label>{t.adminSecondaryEmailLabel} <input type="email" id="admin-field-secondary_email" name="secondary_email" class="adminInput" /></label>
                  <label>{t.adminSecondaryPhoneLabel} <input type="text" id="admin-field-secondary_phone" name="secondary_phone" class="adminInput" /></label>
                </div>
              </div>

              <fieldset class="adminProfileSection">
                <legend class="adminProfileLegend">{t.profileSectionLake}</legend>
                <p class="adminSectionHelp">{t.profileLakeHelp}</p>
                <div class="adminFormGrid">
                  <label>{t.profileLakeCivic} <input type="text" id="admin-field-lake_civic_number" name="lake_civic_number" class="adminInput" /></label>
                  <label>{t.profileLakeStreet} <input type="text" id="admin-field-lake_street_name" name="lake_street_name" class="adminInput" /></label>
                </div>
              </fieldset>

              <div class="adminFormGrid">
                <label class="adminCheckbox"><input type="checkbox" id="admin-field-email_opt_in" name="email_opt_in" /> {t.profileEmailOptIn}</label>
                <label>
                  {t.adminStatusMemberLabel}
                  <select id="admin-field-status" name="status" class="adminInput" title={t.adminStatusMemberFieldTitle}>
                    <option value="new">{t.adminStatusMemberOptionNew}</option>
                    <option value="verified">{t.adminStatusMemberOptionVerified}</option>
                    <option value="disabled">{t.adminStatusMemberOptionDisabled}</option>
                  </select>
                </label>
                <label>{t.adminUserIdLabel} <input type="text" id="admin-field-user_id" name="user_id" class="adminInput" /></label>
                <label class="adminNotes">{t.adminNotesFieldLabel} <textarea id="admin-field-notes" name="notes" class="adminInput" rows="3"></textarea></label>
              </div>
            </div>
            <div class="adminFormActions">
              <button type="submit" class="adminBtn adminBtn--solid">{t.adminSaveMemberBtn}</button>
              <button type="button" class="adminBtn adminBtn--ghost" id="admin-promote-btn" title={t.adminPromoteAdminTitle}>
                {t.adminPromoteBtn}
              </button>
            </div>
          </form>
        </div>

        <div class="adminPanel adminCard">
          <h2 class="adminSubheading">{t.adminDetailSectionMemberships}</h2>
          <div id="admin-detail-memberships-mount" class="adminDetailMembershipList"></div>
        </div>
      </div>
    </div>

    <dialog id="admin-payment-dialog" class="adminDialog">
      <form id="admin-payment-form" class="adminPaymentForm">
        <h3>{t.adminPaymentHeading}</h3>
        <input type="hidden" id="admin-payment-membership-id" value="" />
        <label>
          {t.adminAmountLabel}
          <input id="admin-payment-amount" type="number" name="amount" min="0.01" step="0.01" required class="adminInput" />
        </label>
        <p id="admin-payment-split-preview" class="adminPaymentSplitPreview" hidden aria-live="polite"></p>
        <label>
          {t.adminMethodLabel}
          <select name="method" required class="adminInput">
            <option value="e-transfer">{t.adminMethodEtransfer}</option>
            <option value="cheque">{t.adminMethodCheque}</option>
            <option value="cash">{t.adminMethodCash}</option>
            <option value="unknown">{t.adminMethodUnknown}</option>
          </select>
        </label>
        <label>
          {t.adminDateLabel}
          <input type="date" name="date" class="adminInput" />
        </label>
        <label>
          {t.adminPaymentReferenceLabel}
          <input type="text" name="reference" class="adminInput" autocomplete="off" maxlength="512" />
        </label>
        <label>
          {t.adminNotesLabel}
          <input type="text" name="notes" class="adminInput" />
        </label>
        <div class="adminDialogActions">
          <button type="submit" class="adminBtn adminBtn--solid" value="default">{t.adminSubmitPaymentBtn}</button>
          <button type="button" class="adminBtn adminBtn--ghost" id="admin-payment-cancel">{t.checkoutModalCancel}</button>
        </div>
      </form>
    </dialog>

    <dialog id="admin-add-membership-dialog" class="adminDialog">
      <form id="admin-add-membership-form" class="adminPaymentForm">
        <h3>{t.adminAddMembershipDialogTitle}</h3>
        <label>
          {t.adminMembershipYearLabel}
          <input
            type="number"
            name="year"
            min="2000"
            max="2100"
            step="1"
            required
            class="adminInput"
            id="admin-add-ms-year"
            value={calendarYear}
          />
        </label>
        <label>
          {t.membershipTableType}
          <select name="tier" required class="adminInput" id="admin-add-ms-tier">
            <option value="general">{t.tierGeneral}</option>
            <option value="associate">{t.tierAssociate}</option>
          </select>
        </label>
        <div class="adminAddMsRadios" role="group" aria-label={t.membershipTableStatus}>
          <label class="adminRadioRow">
            <input type="radio" name="initial" value="pending" checked />
            {t.adminAddMemberInitialPending}
          </label>
          <label class="adminRadioRow">
            <input type="radio" name="initial" value="active_with_payment" />
            {t.adminAddMemberInitialPaid}
          </label>
        </div>
        <div id="admin-add-ms-paid" class="adminAddMsPaid" hidden>
          <label>
            {t.adminAmountLabel}
            <input type="number" name="payment_amount" min="0" step="0.01" class="adminInput" />
          </label>
          <label>
            {t.adminMethodLabel}
            <select name="payment_method" class="adminInput">
              <option value="cash">{t.adminMethodCash}</option>
              <option value="e-transfer">{t.adminMethodEtransfer}</option>
              <option value="cheque">{t.adminMethodCheque}</option>
              <option value="unknown">{t.adminMethodUnknown}</option>
            </select>
          </label>
          <label>
            {t.adminDateLabel}
            <input type="date" name="payment_date" class="adminInput" />
          </label>
          <label>
            {t.adminNotesLabel}
            <input type="text" name="payment_notes" class="adminInput" />
          </label>
        </div>
        <div class="adminDialogActions">
          <button type="submit" class="adminBtn adminBtn--solid">{t.adminAddMembershipSubmit}</button>
          <button type="button" class="adminBtn adminBtn--ghost" id="admin-add-membership-cancel">{t.checkoutModalCancel}</button>
        </div>
      </form>
    </dialog>
  </section>
</MemberAppLayout>

<script type="application/json" id="admin-member-detail-data" set:html={JSON.stringify({ adminStrings, tierLabels, memberId, calendarYear, numberLocale })}></script>
<script>
  import { initAdminMemberDetail } from '../../scripts/admin-member-detail';
  const el = document.getElementById('admin-member-detail-data');
  const raw = el?.textContent;
  if (raw) {
    const { adminStrings, tierLabels, memberId, calendarYear, numberLocale } = JSON.parse(raw) as {
      adminStrings: Record<string, string>;
      tierLabels: { general: string; associate: string };
      memberId: string;
      calendarYear: number;
      numberLocale: string;
    };
    initAdminMemberDetail(adminStrings, tierLabels, memberId, calendarYear, numberLocale);
  }
</script>

<style>
  .adminPageMemberDetail.adminPage {
    padding: 1.15rem 0 2.75rem;
  }

  .adminPage {
    --admin-radius: 12px;
    --admin-radius-md: 10px;
    --admin-radius-sm: 8px;
    --admin-border: var(--border);
    --admin-surface: #fff;
    --admin-surface-muted: var(--panel);
    --admin-accent: rgba(28, 95, 118, 0.98);
    --admin-accent-hover: rgba(22, 78, 98, 1);
    --admin-accent-soft: rgba(72, 196, 255, 0.16);
    --admin-text: var(--text);
    --admin-font: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    font-family: var(--admin-font);
    font-size: 0.875rem;
    line-height: 1.5;
    padding: 28px 0 40px;
  }

  .adminConsole {
    max-width: 1100px;
    width: 100%;
    min-width: 0;
    box-sizing: border-box;
  }

  .adminShell {
    background: var(--admin-surface);
    border: 1px solid var(--admin-border);
    border-radius: var(--admin-radius);
    box-shadow: var(--shadow);
    overflow: hidden;
    min-width: 0;
    max-width: 100%;
  }

  .adminStatus {
    margin: 0;
    padding: 0.45rem 1.15rem;
    font-size: 0.8125rem;
    line-height: 1.45;
    border-bottom: 1px solid var(--admin-border);
    background: rgba(72, 196, 255, 0.08);
    color: var(--admin-text);
  }

  .adminStatus[data-error='1'] {
    background: rgba(176, 0, 32, 0.08);
    color: #8a1024;
  }

  .adminStatus[data-success='1'] {
    background: rgba(34, 120, 80, 0.1);
    color: rgba(18, 75, 50, 0.95);
  }

  .adminStatus:empty {
    display: none;
    padding: 0;
    border: none;
  }

  .adminPanel {
    padding: 1.2rem 1.35rem 1.35rem;
    min-width: 0;
  }

  .adminPanel--profile {
    padding-top: 1.15rem;
  }

  .adminPanel + .adminPanel {
    border-top: 1px solid var(--admin-border);
  }

  .adminSubheading {
    font-size: 0.9375rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--admin-border);
    color: var(--admin-text);
  }

  .adminDetailMembershipList {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .adminDetailMembershipList :global(.adminDetailYearToolbar) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1rem;
    margin: 0 0 1.1rem;
    padding: 0.65rem 0.85rem;
    border-radius: var(--admin-radius-sm);
    border: 1px solid var(--admin-border);
    background: var(--admin-surface-muted);
  }

  .adminDetailMembershipList :global(.adminDetailYearToolbarLabel) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.55rem 0.75rem;
    margin: 0;
    font-weight: 600;
    font-size: 0.8125rem;
    color: var(--admin-text);
  }

  .adminDetailMembershipList :global(.adminDetailYearToolbarText) {
    color: var(--muted);
    font-weight: 600;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .adminDetailMembershipList :global(.adminDetailYearPanel) {
    min-width: 0;
  }

  .adminDetailMembershipList :global(.adminDetailPaymentSummary) {
    margin: 0;
    padding: 0.85rem 1rem 0.95rem 1rem;
    border-radius: var(--admin-radius-sm);
    border: 1px solid var(--admin-border);
    border-left: 3px solid rgba(28, 95, 118, 0.55);
    background: var(--admin-surface-muted);
    font-size: 0.8125rem;
    line-height: 1.4;
  }

  .adminDetailMembershipList :global(.adminDetailPaymentSummaryTitleRow) {
    margin: 0 0 0.6rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.07);
  }

  .adminDetailMembershipList :global(.adminDetailPaymentSummaryKicker) {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }

  .adminDetailMembershipList :global(.adminDetailSummaryRow--balanceDue > span:first-child) {
    color: rgba(120, 55, 0, 0.92);
    font-weight: 600;
  }

  .adminDetailMembershipList :global(.adminDetailSummaryValue--due) {
    color: rgba(150, 65, 0, 0.98) !important;
    font-weight: 800 !important;
  }

  .adminDetailMembershipList :global(.adminDetailDuesPaidHint) {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0.7rem 0 0;
    padding: 0.4rem 0.65rem;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(18, 75, 50, 0.95);
    background: rgba(34, 120, 80, 0.09);
    border: 1px solid rgba(34, 120, 80, 0.22);
  }

  .adminDetailMembershipList :global(.adminDetailDuesPaidHint::before) {
    content: '';
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
    background: rgba(34, 120, 80, 0.85);
  }

  .adminDetailMembershipList :global(.adminDetailSummaryRow) {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(5.25rem, max-content);
    column-gap: 1.25rem;
    align-items: baseline;
    padding: 0.38rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.055);
  }

  .adminDetailMembershipList :global(.adminDetailSummaryRow:has(+ .adminDetailSummaryRow--total)) {
    border-bottom: none;
    padding-bottom: 0.2rem;
  }

  .adminDetailMembershipList :global(.adminDetailSummaryRow > span:first-child) {
    color: var(--muted);
    font-weight: 500;
  }

  .adminDetailMembershipList :global(.adminDetailSummaryRow--total) {
    margin-top: 0.2rem;
    padding-top: 0.55rem;
    padding-bottom: 0.15rem;
    border-bottom: none;
    border-top: 1px solid var(--admin-border);
  }

  .adminDetailMembershipList :global(.adminDetailSummaryRow--total > span:first-child) {
    color: var(--admin-text);
    font-weight: 700;
  }

  .adminDetailMembershipList :global(.adminDetailSummaryValue) {
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    text-align: right;
    font-weight: 600;
    color: var(--admin-text);
  }

  .adminDetailMembershipList :global(.adminDetailSummaryRow--total .adminDetailSummaryValue) {
    font-weight: 700;
    font-size: 0.9375rem;
  }

  .adminDetailMembershipList :global(.adminDetailDonationNoteLine) {
    margin: 0.65rem 0 0;
    padding-top: 0.55rem;
    border-top: 1px dashed rgba(0, 0, 0, 0.1);
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.45;
  }

  .adminDetailMembershipList :global(.adminDetailDonationNoteLabel) {
    font-weight: 700;
    color: var(--admin-text);
    margin-right: 0.35rem;
  }

  .adminDetailMembershipList :global(.adminDetailMembershipCard) {
    margin: 0;
    padding: 0;
    border: 1px solid var(--admin-border);
    border-radius: var(--admin-radius-md);
    background: var(--admin-surface);
    box-shadow: 0 1px 3px rgba(15, 25, 35, 0.045);
    overflow: hidden;
    min-width: 0;
  }

  .adminDetailMembershipList :global(.adminDetailMembershipHead) {
    margin: 0;
    padding: 1rem 1.1rem 0.95rem;
    border-bottom: 1px solid var(--admin-border);
    background: rgba(0, 0, 0, 0.015);
  }

  .adminDetailMembershipList :global(.adminDetailMembershipIdentity) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.25rem 1.5rem;
    min-width: 0;
  }

  .adminDetailMembershipList :global(.adminDetailIdentityBlock) {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.35rem;
    min-width: 0;
  }

  .adminDetailMembershipList :global(.adminDetailIdentityLabel) {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--muted);
  }

  .adminDetailMembershipList :global(.adminDetailIdentityValue--tier) {
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--admin-text);
  }

  .adminDetailMembershipList :global(.adminDetailBadge--statusEmphasis) {
    padding: 0.35rem 0.75rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .adminDetailMembershipList :global(.adminDetailBadge) {
    display: inline-block;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.25;
    border: 1px solid transparent;
  }

  .adminDetailMembershipList :global(.adminDetailBadge--tier) {
    background: rgba(255, 255, 255, 0.65);
    border-color: var(--admin-border);
    color: var(--admin-text);
    text-transform: none;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0;
  }

  .adminDetailMembershipList :global(.adminDetailBadge--future) {
    background: rgba(72, 196, 255, 0.14);
    border-color: rgba(28, 95, 118, 0.22);
    color: var(--admin-accent);
    text-transform: none;
    font-size: 0.72rem;
    letter-spacing: 0.02em;
  }

  .adminDetailMembershipList :global(.adminDetailBadge--status.adminDetailBadge--active) {
    background: rgba(34, 120, 80, 0.12);
    border-color: rgba(34, 120, 80, 0.28);
    color: rgba(18, 75, 50, 0.95);
  }

  .adminDetailMembershipList :global(.adminDetailBadge--status.adminDetailBadge--pending) {
    background: rgba(200, 130, 0, 0.12);
    border-color: rgba(180, 110, 0, 0.28);
    color: rgba(90, 55, 0, 0.95);
  }

  .adminDetailMembershipList :global(.adminDetailBadge--status.adminDetailBadge--neutral) {
    background: rgba(0, 0, 0, 0.04);
    border-color: var(--admin-border);
    color: var(--muted);
    text-transform: none;
    font-size: 0.78rem;
  }

  .adminDetailMembershipList :global(.adminDetailPaymentsSection) {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 0;
    min-width: 0;
  }

  .adminDetailMembershipList :global(.adminDetailPaymentsSectionHead) {
    margin: 0;
    padding: 0.65rem 1.1rem 0.55rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    background: var(--admin-surface);
  }

  .adminDetailMembershipList :global(.adminDetailPaymentsTitle) {
    margin: 0;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--admin-text);
  }

  .adminDetailMembershipList :global(.adminDetailPaymentsBody) {
    display: flex;
    flex-direction: column;
    gap: 0;
    min-width: 0;
  }

