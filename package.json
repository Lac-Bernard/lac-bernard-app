{
  "name": "lac-bernard-app",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "tinacms dev -c \"astro dev\"",
    "build": "tinacms build -c \"astro build\"",
    "preview": "astro preview",
    "astro": "astro",
    "db:seed": "node scripts/generate-dummy-seeds.mjs",
    "db:seed:local": "npm run db:seed && supabase db reset",
    "db:seed:apply": "ALLOW_DUMMY_SEED_APPLY=1 node scripts/generate-dummy-seeds.mjs --apply",
    "db:clear-memberships-dev": "ALLOW_CLEAR_MEMBERSHIPS=1 node scripts/clear-memberships-dev.mjs",
    "db:seed-membership-history": "ALLOW_SEED_MEMBERSHIP_HISTORY=1 node scripts/seed-membership-history.mjs",
    "dev:grant-admin": "ALLOW_GRANT_ADMIN_DEV=1 node scripts/grant-admin-dev.mjs",
    "db:import-members-csv": "bash scripts/run-membership-import.sh",
    "db:import-members-csv:local": "bash scripts/run-membership-import.sh --local"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.12",
    "@astrojs/rss": "^4.0.14",
    "@astrojs/sitemap": "^3.6.0",
    "@astrojs/vercel": "^9.0.1",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "@vercel/analytics": "^2.0.1",
    "astro": "^5.16.0",
    "cookie": "^1.1.1",
    "sharp": "^0.34.3",
    "stripe": "^17.7.0",
    "tinacms": "^2.9.5"
  },
  "devDependencies": {
    "@tinacms/cli": "^1.12.4",
    "@types/node": "^24.10.1",
    "supabase": "^2.83.0"
  }
}
