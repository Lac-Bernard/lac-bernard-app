TINA_CLIENT_ID=
TINA_TOKEN=
# Local Supabase only: `supabase/config.toml` maps these to [auth.external.google] via env(GOOGLE_*).
# The Astro app does not read them — Google sign-in uses `signInWithOAuth` against Supabase Auth.
# For hosted Supabase, set the Google provider (client id + secret) in the Dashboard, not in Vercel.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional. If unset, the app derives the origin from request headers (see src/lib/http/public-origin.ts).
PUBLIC_SITE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Server-only: membership admin API routes (never expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=
# Local bootstrap: grant admin by email when Studio app metadata is awkward — `npm run dev:grant-admin -- you@example.com` (see scripts/grant-admin-dev.mjs).
# Server-only: Stripe (see plan §6 — test keys locally, live keys in Vercel Production).
# STRIPE_WEBHOOK_SECRET: use `whsec_…` from `stripe listen` while developing; use the Dashboard
# endpoint signing secret in production.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Server-only: Google Sheets sync (service account JSON should stay on one line in .env).
# Same account powers /api/drive/list for embedded folder browsers: enable Google Drive API in GCP,
# grant the service account the Drive API scope (readonly), and share each public archive folder
# with the service account email (Viewer). New roots must be added to src/lib/googleDrive/allowedFolderRoots.ts.
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
CRON_SECRET=
# --- Daily membership admin summary email (Vercel cron → /api/cron/membership-admin-daily-summary) ---
# vercel.json runs at 10:00 UTC (~6:00 AM America/Toronto during EDT; ~5:00 AM during EST — change the cron expression for a fixed local time year-round).
#
# Google Workspace (send as the bot / service mailbox, e.g. bot@yourdomain.ca):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=bot@yourdomain.ca          # full Workspace email
#   SMTP_PASS=xxxx xxxx xxxx xxxx         # App Password (16 chars), not your normal password
#   MEMBERSHIP_ADMIN_SUMMARY_FROM=bot@yourdomain.ca
# Get an App Password: sign in as that user → Google Account → Security → 2-Step Verification must be ON
#   → App passwords → create one for “Mail” / “Other”. If you don’t see App passwords, your Workspace admin
#   may need to allow them (Admin console → Security → Authentication → Less secure apps / App passwords policy).
# Alternate for org-wide devices: SMTP relay https://support.google.com/a/answer/2956491 (often IP-based; less suited to Vercel).
#
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Use SMTP_SECURE=true with port 465 (implicit TLS).
# SMTP_SECURE=
MEMBERSHIP_ADMIN_SUMMARY_FROM=bot@lacbernard.ca
# Comma-separated OK, e.g. membership@lacbernard.ca, treasurer@lacbernard.ca
MEMBERSHIP_ADMIN_SUMMARY_TO=membership@lacbernard.ca